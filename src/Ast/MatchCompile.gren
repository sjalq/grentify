module Ast.MatchCompile exposing
    ( collectSoleCtorsFromFile
    , compile
    , hasUnportedListPatterns
    , unportedListSummary
    )

{-| Binder-preserving list/cons match compiler.

List patterns lower to nested `Array.popFirst` matches where **user binders
live in Gren patterns** (`Just { first = x, rest = xs }`), not reconstructed
lets. Synthetic names are only for intermediate list temps.

Law: free variables of each arm body stay bound by the compiled pattern tree.

Gren forbids shadowing, so every pattern binder is α-renamed against an
occupied-name scope before placement; free occurrences in the arm body are
renamed to match. Outer `as` names on cons arms bind the whole list.

Sole-constructor custom types (package-wide) are irrefutable when their nested
patterns are irrefutable — peel matches must not emit a dead `_` arm (Gren
REDUNDANT PATTERN).
-}

import Array exposing ( Array )
import Ast.Types exposing
    ( CaseArm
    , Declaration(..)
    , Expr(..)
    , File
    , LetDecl(..)
    , NamedRef
    , Pattern(..)
    )
import Ast.Walk as Walk
import Dict exposing ( Dict )
import Maybe exposing ( Maybe(..) )

-- SCOPE / α-RENAME ------------------------------------------------------------


type alias Scope =
    { occupied : Dict String {} }


emptyScope : Scope
emptyScope =
    { occupied = Dict.empty }


occupy : String -> Scope -> Scope
occupy name scope =
    { occupied = Dict.set name {} scope.occupied }


occupyAll : Array String -> Scope -> Scope
occupyAll names scope =
    Array.foldl occupy scope names


freshName : String -> Scope -> String
freshName base scope =
    if not (Dict.member base scope.occupied) then
        base

    else
        freshNameHelp base 1 scope


freshNameHelp : String -> Int -> Scope -> String
freshNameHelp base n scope =
    let
        candidate =
            base ++ "_" ++ String.fromInt n
    in
    if Dict.member candidate scope.occupied then
        freshNameHelp base (n + 1) scope

    else
        candidate


{-| Bind one name: keep if free, else freshen. Returns subst old→new when renamed.
-}
bindName :
    String
    -> Scope
    -> { name : String, scope : Scope, subst : Dict String String }
bindName name scope =
    let
        newName =
            freshName name scope
    in
    { name = newName
    , scope = occupy newName scope
    , subst =
        if newName == name then
            Dict.empty

        else
            Dict.singleton name newName
    }


mergeSubst : Dict String String -> Dict String String -> Dict String String
mergeSubst left right =
    Array.foldl
        (\key acc ->
            when Dict.get key right is
                Just value ->
                    Dict.set key value acc

                Nothing ->
                    acc) left (Dict.keys right)


type alias BindResult =
    { pattern : Pattern
    , scope : Scope
    , subst : Dict String String
    }


bindPattern : Pattern -> Scope -> BindResult
bindPattern pattern scope =
    when pattern is
        PatVar name ->
            let
                bound =
                    bindName name scope
            in
            { pattern = PatVar bound.name
            , scope = bound.scope
            , subst = bound.subst
            }

        PatAll ->
            { pattern = PatAll, scope = scope, subst = Dict.empty }

        PatAs { pattern = inner, name = name } ->
            let
                innerR =
                    bindPattern inner scope

                bound =
                    bindName name innerR.scope
            in
            { pattern = PatAs { pattern = innerR.pattern, name = bound.name }
            , scope = bound.scope
            , subst = mergeSubst innerR.subst bound.subst
            }

        PatNamed { ref = ref, arguments = args } ->
            let
                folded =
                    bindPatternList args scope
            in
            { pattern = PatNamed { ref = ref, arguments = folded.patterns }
            , scope = folded.scope
            , subst = folded.subst
            }

        PatTuple items ->
            let
                folded =
                    bindPatternList items scope
            in
            { pattern = PatTuple folded.patterns
            , scope = folded.scope
            , subst = folded.subst
            }

        PatList items ->
            let
                folded =
                    bindPatternList items scope
            in
            { pattern = PatList folded.patterns
            , scope = folded.scope
            , subst = folded.subst
            }

        PatCons { head = head, tail = tail } ->
            let
                headR =
                    bindPattern head scope

                tailR =
                    bindPattern tail headR.scope
            in
            { pattern = PatCons { head = headR.pattern, tail = tailR.pattern }
            , scope = tailR.scope
            , subst = mergeSubst headR.subst tailR.subst
            }

        PatRecordBind fields ->
            let
                folded =
                    Array.foldl
                        (\field acc ->
                            let
                                r =
                                    bindPattern field.pattern acc.scope
                            in
                            { patterns =
                                Array.pushLast
                                    { name = field.name, pattern = r.pattern }
                                    acc.patterns
                            , scope = r.scope
                            , subst = mergeSubst acc.subst r.subst
                            })
                        { patterns = [], scope = scope, subst = Dict.empty }
                        fields
            in
            { pattern = PatRecordBind folded.patterns
            , scope = folded.scope
            , subst = folded.subst
            }

        PatRecord names ->
            { pattern = PatRecord names, scope = scope, subst = Dict.empty }

        _ ->
            { pattern = pattern, scope = scope, subst = Dict.empty }


bindPatternList :
    Array Pattern
    -> Scope
    -> { patterns : Array Pattern, scope : Scope, subst : Dict String String }
bindPatternList patterns scope =
    Array.foldl
        (\pat acc ->
            let
                r =
                    bindPattern pat acc.scope
            in
            { patterns = Array.pushLast r.pattern acc.patterns
            , scope = r.scope
            , subst = mergeSubst acc.subst r.subst
            }) { patterns = [], scope = scope, subst = Dict.empty } patterns


patternBinders : Pattern -> Array String
patternBinders pattern =
    when pattern is
        PatVar name ->
            [ name ]

        PatAs { pattern = inner, name = name } ->
            Array.pushLast name (patternBinders inner)

        PatNamed { arguments = args } ->
            Array.foldl (\p acc -> Array.append acc (patternBinders p)) [] args

        PatTuple items ->
            Array.foldl (\p acc -> Array.append acc (patternBinders p)) []
                items

        PatList items ->
            Array.foldl (\p acc -> Array.append acc (patternBinders p)) []
                items

        PatCons { head = head, tail = tail } ->
            Array.append (patternBinders head) (patternBinders tail)

        PatRecordBind fields ->
            Array.foldl (\f acc -> Array.append acc (patternBinders f.pattern))
                [] fields

        _ ->
            []


{-| Rename free variables according to subst. Binders shadow subst entries.
-}
renameExpr : Dict String String -> Expr -> Expr
renameExpr subst expr =
    if Array.isEmpty (Dict.keys subst) then
        expr

    else
        renameExprHelp subst expr


renameExprHelp : Dict String String -> Expr -> Expr
renameExprHelp subst expr =
    when expr is
        ExprVar ref ->
            when ref.moduleName is
                Just _ ->
                    expr

                Nothing ->
                    when Dict.get ref.name subst is
                        Just newName ->
                            ExprVar { moduleName = Nothing, name = newName }

                        Nothing ->
                            expr

        ExprApplication parts ->
            ExprApplication (Array.map (renameExprHelp subst) parts)

        ExprBinop { operator = op, left = left, right = right } ->
            ExprBinop
                { operator = op
                , left = renameExprHelp subst left
                , right = renameExprHelp subst right
                }

        ExprIf { condition = c, then_ = t, else_ = e } ->
            ExprIf
                { condition = renameExprHelp subst c
                , then_ = renameExprHelp subst t
                , else_ = renameExprHelp subst e
                }

        ExprNegation inner ->
            ExprNegation (renameExprHelp subst inner)

        ExprTuple items ->
            ExprTuple (Array.map (renameExprHelp subst) items)

        ExprList items ->
            ExprList (Array.map (renameExprHelp subst) items)

        ExprRecord fields ->
            ExprRecord
                (Array.map
                    (\f ->
                        { name = f.name, value = renameExprHelp subst f.value })
                    fields)

        ExprAccess { record = record, field = field } ->
            ExprAccess { record = renameExprHelp subst record, field = field }

        ExprUpdate { name = name, fields = fields } ->
            let
                newName =
                    when Dict.get name subst is
                        Just n ->
                            n

                        Nothing ->
                            name
            in
            ExprUpdate
                { name = newName
                , fields =
                    Array.map
                        (\f ->
                            { name = f.name
                            , value = renameExprHelp subst f.value
                            }) fields
                }

        ExprLambda { arguments = arguments, expression = body } ->
            let
                binders =
                    Array.foldl (\p acc -> Array.append acc (patternBinders p))
                        [] arguments

                bodySubst =
                    dropKeys binders subst
            in
            ExprLambda
                { arguments = arguments
                , expression = renameExprHelp bodySubst body
                }

        ExprLet { declarations = declarations, expression = body } ->
            renameLet subst declarations body

        ExprCase { expression = scrutinee, cases = arms } ->
            ExprCase
                { expression = renameExprHelp subst scrutinee
                , cases =
                    Array.map
                        (\arm ->
                            let
                                binders =
                                    patternBinders arm.pattern

                                bodySubst =
                                    dropKeys binders subst
                            in
                            { pattern = arm.pattern
                            , body = renameExprHelp bodySubst arm.body
                            }) arms
                }

        _ ->
            expr


dropKeys : Array String -> Dict String String -> Dict String String
dropKeys keys dict =
    let
        dropSet =
            Array.foldl (\k s -> Dict.set k {} s) Dict.empty keys
    in
    Array.foldl
        (\k acc ->
            if Dict.member k dropSet then
                acc

            else
                when Dict.get k dict is
                    Just v ->
                        Dict.set k v acc

                    Nothing ->
                        acc) Dict.empty (Dict.keys dict)


renameLet : Dict String String -> Array LetDecl -> Expr -> Expr
renameLet subst declarations body =
    let
        step =
            Array.foldl
                (\decl acc ->
                    when decl is
                        LetFunction fn ->
                            let
                                argBinders =
                                    Array.foldl
                                        (\p a ->
                                            Array.append a (patternBinders p))
                                        [] fn.arguments

                                -- Name + args shadow free renames inside the fn body.
                                fnBodySubst =
                                    dropKeys (Array.pushLast fn.name argBinders)
                                        acc.subst

                                newDecl =
                                    LetFunction
                                        { fn | expression =
                                            renameExprHelp fnBodySubst
                                                fn.expression
                                        }
                            in
                            { decls = Array.pushLast newDecl acc.decls
                            , subst = dropKeys [ fn.name ] acc.subst
                            }

                        LetDestructure
                            { pattern = pattern, expression = expression } ->
                            let
                                binders =
                                    patternBinders pattern

                                newDecl =
                                    LetDestructure
                                        { pattern = pattern
                                        , expression =
                                            renameExprHelp acc.subst expression
                                        }
                            in
                            { decls = Array.pushLast newDecl acc.decls
                            , subst = dropKeys binders acc.subst
                            }) { decls = [], subst = subst } declarations
    in
    ExprLet
        { declarations = step.decls
        , expression = renameExprHelp step.subst body
        }


{-| `"Module.Ctor"` (and short names) for custom types with exactly one constructor.
-}
collectSoleCtorsFromFile : File -> Dict String {}
collectSoleCtorsFromFile file =
    let
        moduleName =
            file.moduleDefinition.moduleName
    in
    Array.foldl
        (\declaration acc ->
            when declaration is
                DeclCustomType custom ->
                    if Array.length custom.constructors == 1 then
                        when Array.first custom.constructors is
                            Just ctor ->
                                acc
                                    |> Dict.set (moduleName ++ "." ++ ctor.name)
                                        {}
                                    |> Dict.set ctor.name {}

                            Nothing ->
                                acc

                    else
                        acc

                _ ->
                    acc) Dict.empty file.declarations


type alias SoleCtors =
    Dict String {}


compile : SoleCtors -> File -> File
compile packageSole file =
    let
        sole =
            mergeSoleCtors packageSole (collectSoleCtorsFromFile file)
    in
    { file | declarations =
        Array.indexedMap (\i d -> compileDeclaration sole (i * 100003) d)
            file.declarations
    }


mergeSoleCtors : SoleCtors -> SoleCtors -> SoleCtors
mergeSoleCtors package local =
    Dict.foldl Dict.set package local


hasUnportedListPatterns : File -> Bool
hasUnportedListPatterns file =
    Array.any declarationHasUnported file.declarations


{-| Diagnostic: where residual list/cons patterns remain after compile.
-}
unportedListSummary : File -> String
unportedListSummary file =
    file.declarations
        |> Array.indexedMap
            (\i declaration ->
                if declarationHasUnported declaration then
                    Just
                        ("decl#"
                            ++ String.fromInt i
                            ++ " "
                            ++ declarationLabel declaration
                            ++ ": "
                            ++ String.join ", "
                                (declarationUnportedSites declaration))

                else
                    Nothing)
        |> Array.mapAndKeepJust (\m -> m)
        |> String.join "; "


declarationLabel : Declaration -> String
declarationLabel declaration =
    when declaration is
        DeclFunction fn ->
            fn.name

        DeclDestructure _ ->
            "<destructure>"

        DeclAlias a ->
            a.name

        DeclCustomType c ->
            c.name

        DeclPort s ->
            s.name

        DeclInfix ->
            "<infix>"


declarationUnportedSites : Declaration -> Array String
declarationUnportedSites declaration =
    when declaration is
        DeclFunction fn ->
            let
                argHits =
                    if Array.any patternHasUnportedList fn.arguments then
                        [ "args" ]

                    else
                        []
            in
            Array.foldl Array.pushLast argHits
                (exprUnportedSites fn.expression)

        DeclDestructure { pattern = pattern, expression = expression } ->
            let
                p =
                    if patternHasUnportedList pattern then
                        [ "destructure-pat" ]

                    else
                        []
            in
            Array.foldl Array.pushLast p (exprUnportedSites expression)

        _ ->
            []


exprUnportedSites : Expr -> Array String
exprUnportedSites expr =
    let
        here =
            when expr is
                ExprCase { cases = arms } ->
                    if
                        Array.any (\a -> patternHasUnportedList a.pattern) arms
                    then
                        [ "case{"
                            ++ String.join "|"
                                (Array.map (\a -> patternKind a.pattern) arms)
                            ++ "}"
                        ]

                    else
                        []

                ExprLambda { arguments = arguments } ->
                    if Array.any patternHasUnportedList arguments then
                        [ "lambda-args" ]

                    else
                        []

                ExprLet { declarations = declarations } ->
                    if Array.any letPatternsUnported declarations then
                        [ "let-pat" ]

                    else
                        []

                _ ->
                    []
    in
    Walk.foldExprChildren
        (\child acc -> Array.foldl Array.pushLast acc (exprUnportedSites child))
        here expr


patternKind : Pattern -> String
patternKind pattern =
    when pattern is
        PatCons _ ->
            "cons"

        PatList items ->
            "list" ++ String.fromInt (Array.length items)

        PatAll ->
            "_"

        PatVar _ ->
            "var"

        PatNamed { ref = ref } ->
            "named:" ++ ref.name

        PatTuple items ->
            "tuple" ++ String.fromInt (Array.length items)

        PatAs { pattern = inner } ->
            "as(" ++ patternKind inner ++ ")"

        PatRecordBind _ ->
            "recbind"

        _ ->
            "other"

-- TREE WALK ------------------------------------------------------------------


compileDeclaration : SoleCtors -> Int -> Declaration -> Declaration
compileDeclaration sole seed declaration =
    when declaration is
        DeclFunction fn ->
            let
                body =
                    compileExpr sole (seed + 1) fn.expression

                rewritten =
                    rewriteConsArgs sole (seed + 2) fn.arguments body
            in
            DeclFunction
                { fn
                    | arguments = rewritten.arguments
                    , expression = rewritten.expression
                }

        DeclDestructure { pattern = pattern, expression = expression } ->
            let
                body =
                    compileExpr sole (seed + 1) expression

                rewritten =
                    rewriteConsArgs sole (seed + 2) [ pattern ] body
            in
            when Array.first rewritten.arguments is
                Just p ->
                    DeclDestructure
                        { pattern = p, expression = rewritten.expression }

                Nothing ->
                    DeclDestructure { pattern = pattern, expression = body }

        _ ->
            declaration


compileExpr : SoleCtors -> Int -> Expr -> Expr
compileExpr sole seed expr =
    when expr is
        ExprCase { expression = scrutinee, cases = arms } ->
            let
                compiledScrut =
                    compileExpr sole (seed + 1) scrutinee

                compiledArms =
                    Array.indexedMap
                        (\i arm ->
                            { pattern = arm.pattern
                            , body =
                                compileExpr sole (seed + 10 + i * 97) arm.body
                            }) arms

                caseBlock =
                    { expression = compiledScrut, cases = compiledArms }
            in
            when compileListishCase sole (seed + 3) caseBlock is
                Just rewritten ->
                    rewritten

                Nothing ->
                    if
                        Array.any (\a -> patternHasUnportedList a.pattern)
                            compiledArms
                    then
                        -- Nested lists under Just/tuples/ctors (e.g. Just (x, []))
                        -- are not "listish cases" but still need peels.
                        compileGeneralCase sole (seed + 5) compiledScrut
                            compiledArms

                    else
                        ExprCase caseBlock

        ExprLambda { arguments = arguments, expression = body } ->
            let
                compiledBody =
                    compileExpr sole (seed + 1) body

                rewritten =
                    rewriteConsArgs sole (seed + 2) arguments compiledBody
            in
            ExprLambda
                { arguments = rewritten.arguments
                , expression = rewritten.expression
                }

        ExprLet { declarations = declarations, expression = body } ->
            let
                compiledBody =
                    compileExpr sole (seed + 1) body

                -- Elm/Gren lets are mutually recursive in one block. Nesting
                -- each decl as `let a = … in let b = …` breaks forward refs
                -- (e.g. `ts = map t …` before `t i = …`). Only peel-fold when
                -- a destructure needs list/cons totalization.
                needsListPeel =
                    Array.any letDeclNeedsListPeel declarations
            in
            if needsListPeel then
                Array.indexedFoldr
                    (\i declaration currentBody ->
                        compileLetDeclInto sole (seed + 20 + i * 31) declaration
                            currentBody) compiledBody declarations

            else
                ExprLet
                    { declarations =
                        Array.indexedMap
                            (\i declaration ->
                                compileLetDeclKeep sole (seed + 20 + i * 31)
                                    declaration) declarations
                    , expression = compiledBody
                    }

        -- Seeded uniqueness only matters for case/lambda peels above.
        _ ->
            Walk.mapExprChildren (compileExpr sole (seed + 1)) expr


{-| True when a let bind must become a list/cons peel (cannot stay in one block).
-}
letDeclNeedsListPeel : LetDecl -> Bool
letDeclNeedsListPeel declaration =
    when declaration is
        LetDestructure { pattern = pattern } ->
            patternHasUnportedList pattern

        LetFunction _ ->
            False


{-| Compile one let declaration in place (same mutual block).
-}
compileLetDeclKeep : SoleCtors -> Int -> LetDecl -> LetDecl
compileLetDeclKeep sole seed declaration =
    when declaration is
        LetFunction fn ->
            let
                fnBody =
                    compileExpr sole (seed + 1) fn.expression

                rewritten =
                    rewriteConsArgs sole (seed + 2) fn.arguments fnBody
            in
            LetFunction
                { fn
                    | arguments = rewritten.arguments
                    , expression = rewritten.expression
                }

        LetDestructure { pattern = pattern, expression = expression } ->
            LetDestructure
                { pattern = pattern
                , expression = compileExpr sole (seed + 1) expression
                }


{-| Turn one let declaration into a binding wrapped around `body`.
List patterns in the bind become peels (same law as case/lambda).
Only used when the block needs list peels (see `letDeclNeedsListPeel`).
-}
compileLetDeclInto : SoleCtors -> Int -> LetDecl -> Expr -> Expr
compileLetDeclInto sole seed declaration body =
    when declaration is
        LetFunction fn ->
            let
                fnBody =
                    compileExpr sole (seed + 1) fn.expression

                rewritten =
                    rewriteConsArgs sole (seed + 2) fn.arguments fnBody
            in
            ExprLet
                { declarations =
                    [ LetFunction
                        { fn
                            | arguments = rewritten.arguments
                            , expression = rewritten.expression
                        }
                    ]
                , expression = body
                }

        LetDestructure { pattern = pattern, expression = expression } ->
            let
                value =
                    compileExpr sole (seed + 1) expression
            in
            if patternHasUnportedList pattern then
                matchPattern sole (seed + 2) emptyScope pattern value body
                    (todo "elm-to-gren: let list pattern mismatch")

            else
                ExprLet
                    { declarations =
                        [ LetDestructure
                            { pattern = pattern, expression = value }
                        ]
                    , expression = body
                    }


compileLetDecl : SoleCtors -> Int -> LetDecl -> LetDecl
compileLetDecl sole seed declaration =
    Walk.mapLetDecl (compileExpr sole (seed + 1)) (\p -> p) declaration

-- GENERAL PATTERN MATCH (nested lists anywhere) ------------------------------


{-| Sequential arm tries: first arm that matches wins; nested list peels included.
Used when specialized listish case paths do not apply (e.g. `Just (x, [])`).
-}
compileGeneralCase : SoleCtors -> Int -> Expr -> Array CaseArm -> Expr
compileGeneralCase sole seed scrutinee arms =
    let
        scrut =
            "gs_" ++ String.fromInt seed

        failEnd =
            todo "elm-to-gren: non-exhaustive pattern match"

        -- Bind each fallthrough as `fl_ = \_ -> next` and call `fl_ {}` from peels.
        -- Inlining `nextFail` into every peel branch makes a DAG that *Print*
        -- expands exponentially (hang on multi-arm fixed lists: color/md5/iso8601).
        chain =
            Array.indexedFoldr
                (\i arm nextFail ->
                    let
                        failFn =
                            "fl_" ++ String.fromInt (seed + 1 + i * 100003)

                        nextFailCall =
                            ExprApplication [ var failFn, ExprUnit ]

                        armExpr =
                            matchPattern sole (seed + 2 + i * 100003)
                                (occupy scrut (occupy failFn emptyScope))
                                arm.pattern (var scrut) arm.body nextFailCall
                    in
                    ExprLet
                        { declarations =
                            [ LetFunction
                                { name = failFn
                                , arguments = [ PatAll ]
                                , expression = nextFail
                                }
                            ]
                        , expression = armExpr
                        }) failEnd arms
    in
    wrapLet scrut scrutinee chain


{-| Match `pattern` against `value`. On success run `body`; on failure `fail`.
Recursively peels list/cons patterns at any depth (tuple fields, ctor args, …).
-}
matchPattern :
    SoleCtors
    -> Int
    -> Scope
    -> Pattern
    -> Expr
    -> Expr
    -> Expr
    -> Expr
matchPattern sole seed scope pattern value body fail =
    when pattern is
        PatAll ->
            body

        PatVar name ->
            wrapLet name value body

        PatAs { pattern = inner, name = name } ->
            let
                bound =
                    bindName name scope
            in
            wrapLet bound.name value
                (matchPattern sole (seed + 1) bound.scope inner (var bound.name)
                    (renameExpr bound.subst body) fail)

        PatUnit ->
            body

        PatChar _ ->
            matchLiteral pattern value body fail

        PatString _ ->
            matchLiteral pattern value body fail

        PatInt _ ->
            matchLiteral pattern value body fail

        PatHex _ ->
            matchLiteral pattern value body fail

        PatFloat _ ->
            matchLiteral pattern value body fail

        PatList members ->
            if Array.isEmpty members then
                ExprCase
                    { expression = popFirst value
                    , cases =
                        [ { pattern = nothingPat, body = body }
                        , { pattern = PatAll, body = fail }
                        ]
                    }

            else
                matchListShape sole seed scope members (PatList []) value body
                    fail

        PatCons _ ->
            when consHeadsRest pattern is
                Just { heads = heads, rest = rest } ->
                    matchListShape sole seed scope heads rest value body fail

                Nothing ->
                    fail

        PatTuple items ->
            let
                labels =
                    tupleBindLabels (Array.length items)

                fields =
                    Array.map2 (\label item -> { name = label, pattern = item })
                        labels items
            in
            matchRecordFields sole seed scope fields value body fail

        PatRecord names ->
            -- Shallow record pattern `{ a, b }` — bind whole value, fields are names.
            wrapDestructure pattern value body

        PatRecordBind fields ->
            matchRecordFields sole seed scope fields value body fail

        PatNamed { ref = ref, arguments = args } ->
            matchNamedPattern sole seed scope ref args value body fail


matchLiteral : Pattern -> Expr -> Expr -> Expr -> Expr
matchLiteral pattern value body fail =
    ExprCase
        { expression = value
        , cases =
            [ { pattern = pattern, body = body }
            , { pattern = PatAll, body = fail }
            ]
        }


matchListShape :
    SoleCtors
    -> Int
    -> Scope
    -> Array Pattern
    -> Pattern
    -> Expr
    -> Expr
    -> Expr
    -> Expr
matchListShape sole seed scope heads rest value body fail =
    let
        listB =
            bindName ("ml_" ++ String.fromInt seed) scope
    in
    wrapLet listB.name value
        (matchListHeads sole (seed + 1) listB.scope listB.name heads rest body
            fail)


{-| Peel `listName` for heads/rest, desugaring nested list patterns in heads.
-}
matchListHeads :
    SoleCtors
    -> Int
    -> Scope
    -> String
    -> Array Pattern
    -> Pattern
    -> Expr
    -> Expr
    -> Expr
matchListHeads sole seed scope listName heads rest body fail =
    when Array.popFirst heads is
        Nothing ->
            -- No heads: only rest (open list or exact empty).
            when rest is
                PatVar restName ->
                    wrapLet restName (var listName) body

                PatAll ->
                    body

                PatList members ->
                    if Array.isEmpty members then
                        ExprCase
                            { expression = popFirst (var listName)
                            , cases =
                                [ { pattern = nothingPat, body = body }
                                , { pattern = PatAll, body = fail }
                                ]
                            }

                    else
                        matchListShape sole seed scope members (PatList [])
                            (var listName) body fail

                _ ->
                    if isEmptyList rest then
                        ExprCase
                            { expression = popFirst (var listName)
                            , cases =
                                [ { pattern = nothingPat, body = body }
                                , { pattern = PatAll, body = fail }
                                ]
                            }

                    else
                        matchPattern sole seed scope rest (var listName) body
                            fail

        Just { first = headPat, rest = moreHeads } ->
            let
                hB =
                    bindName ("mh_" ++ String.fromInt seed) scope

                tB =
                    bindName ("mt_" ++ String.fromInt seed) hB.scope

                afterHead =
                    matchPattern sole (seed + 1) tB.scope headPat (var hB.name)
                        (matchListHeads sole (seed + 2) tB.scope tB.name
                            moreHeads rest body fail) fail
            in
            ExprCase
                { expression = popFirst (var listName)
                , cases =
                    [ { pattern = nothingPat
                      , body = fail
                      }
                    , { pattern = justRecord (PatVar hB.name) (PatVar tB.name)
                      , body = afterHead
                      }
                    ]
                }


matchRecordFields :
    SoleCtors
    -> Int
    -> Scope
    -> Array { name : String, pattern : Pattern }
    -> Expr
    -> Expr
    -> Expr
    -> Expr
matchRecordFields sole seed scope fields value body fail =
    let
        tempB =
            bindName ("rf_" ++ String.fromInt seed) scope

        -- Refutable fields first so fail-continuations are NOT nested under
        -- irrefutable binders (`let first = …` wrapping the next case arm).
        refutable =
            Array.keepIf (\f -> not (isIrrefutable sole f.pattern)) fields

        irrefutable =
            Array.keepIf (\f -> isIrrefutable sole f.pattern) fields

        peelField i field cont =
            matchPattern sole (seed + 3 + i * 97) tempB.scope field.pattern
                (ExprAccess { record = var tempB.name, field = field.name })
                cont fail

        afterIrref =
            Array.indexedFoldr peelField body irrefutable

        peeled =
            Array.indexedFoldr
                (\i field cont ->
                    peelField (i + Array.length irrefutable) field cont)
                afterIrref refutable
    in
    wrapLet tempB.name value peeled


matchNamedPattern :
    SoleCtors
    -> Int
    -> Scope
    -> NamedRef
    -> Array Pattern
    -> Expr
    -> Expr
    -> Expr
    -> Expr
matchNamedPattern sole seed scope ref args value body fail =
    if Array.isEmpty args then
        if isIrrefutable sole (PatNamed { ref = ref, arguments = [] }) then
            body

        else
            ExprCase
                { expression = value
                , cases =
                    [ { pattern = PatNamed { ref = ref, arguments = [] }
                      , body = body
                      }
                    , { pattern = PatAll
                      , body = fail
                      }
                    ]
                }

    else if Array.any patternHasUnportedList args || Array.length args > 1 then
        -- Bind ctor payload args to temps (Gren multi-arg → one record, or 1-arg).
        let
            temps =
                Array.indexedMap
                    (\i _ ->
                        "na_" ++ String.fromInt seed ++ "_" ++ String.fromInt i)
                    args

            argPats =
                Array.map PatVar temps

            namedPat =
                PatNamed { ref = ref, arguments = argPats }

            afterMatch =
                Array.indexedFoldr
                    (\i argPat cont ->
                        when Array.get i temps is
                            Just t ->
                                matchPattern sole (seed + 1 + i)
                                    (occupyAll temps scope) argPat (var t) cont
                                    fail

                            Nothing ->
                                cont) body args

            matchExpr =
                if
                    isIrrefutable sole
                        (PatNamed { ref = ref, arguments = args })
                then
                    wrapDestructure namedPat value afterMatch

                else
                    ExprCase
                        { expression = value
                        , cases =
                            [ { pattern = namedPat, body = afterMatch }
                            , { pattern = PatAll, body = fail }
                            ]
                        }
        in
        matchExpr

    else
        -- Single arg, no nested lists: keep prior sole-ctor / when behaviour.
        matchNamed sole (PatNamed { ref = ref, arguments = args }) value body
            fail

-- LISTISH CASE ENTRY ---------------------------------------------------------


compileListishCase :
    SoleCtors
    -> Int
    -> { expression : Expr, cases : Array CaseArm }
    -> Maybe Expr
compileListishCase sole seed caseBlock =
    when tryPlainListCase sole seed caseBlock is
        Just e ->
            Just e

        Nothing ->
            when tryMaybeListCase sole seed caseBlock is
                Just e ->
                    Just e

                Nothing ->
                    when tryResultListCase sole seed caseBlock is
                        Just e ->
                            Just e

                        Nothing ->
                            when tryCtorEmbeddedCase sole seed caseBlock is
                                Just e ->
                                    Just e

                                Nothing ->
                                    tryTupleListCase sole seed caseBlock

-- PLAIN LIST CASE ------------------------------------------------------------


tryPlainListCase :
    SoleCtors
    -> Int
    -> { expression : Expr, cases : Array CaseArm }
    -> Maybe Expr
tryPlainListCase sole seed caseBlock =
    if not (isPlainListCase caseBlock.cases) then
        Nothing

    else if not (listCaseNeedsConsPeel caseBlock.cases) then
        -- Pure fixed array patterns: leave as `when xs is [a,b,c] -> …`.
        -- Peeling multi-arm fixed lists hangs (exponential Print/transform).
        Nothing

    else
        Just (compileListCase sole seed caseBlock.expression caseBlock.cases)


{-| True when any arm uses open cons (`::`) and must be peeled.
-}
listCaseNeedsConsPeel : Array CaseArm -> Bool
listCaseNeedsConsPeel arms =
    Array.any (\a -> patternHasCons a.pattern) arms


isPlainListCase : Array CaseArm -> Bool
isPlainListCase arms =
    Array.any (\a -> isListShape a.pattern) arms
        && Array.all (\a -> isListCaseArm a.pattern) arms


isListShape : Pattern -> Bool
isListShape pattern =
    when pattern is
        PatList _ ->
            True

        PatCons _ ->
            True

        PatAs { pattern = inner } ->
            isListShape inner

        _ ->
            False


isListCaseArm : Pattern -> Bool
isListCaseArm pattern =
    when pattern is
        PatAll ->
            True

        PatVar _ ->
            True

        PatList members ->
            Array.all isCompilableHead members

        PatCons _ ->
            when consHeadsRest pattern is
                Just { heads = heads, rest = rest } ->
                    Array.all isCompilableHead heads && isCompilableRest rest

                Nothing ->
                    False

        PatAs { pattern = inner } ->
            isListCaseArm inner

        _ ->
            False


isCompilableHead : Pattern -> Bool
isCompilableHead pattern =
    when pattern is
        PatVar _ ->
            True

        PatAll ->
            True

        PatNamed { arguments = args } ->
            Array.all isCompilableHead args

        PatTuple items ->
            Array.all isCompilableHead items

        PatRecord _ ->
            True

        PatRecordBind fields ->
            Array.all (\f -> isCompilableHead f.pattern) fields

        PatAs { pattern = inner } ->
            isCompilableHead inner

        PatList members ->
            -- Nested list head: allow if we can compile it (rare).
            Array.all isCompilableHead members

        PatCons _ ->
            isListCaseArm pattern

        _ ->
            not (patternHasCons pattern)


isCompilableRest : Pattern -> Bool
isCompilableRest pattern =
    when pattern is
        PatVar _ ->
            True

        PatAll ->
            True

        PatList members ->
            Array.isEmpty members

        PatAs { pattern = inner } ->
            isCompilableRest inner

        _ ->
            False


{-| Compile a list case: bind scrutinee, peel with popFirst, binders in patterns.

Multi-arm *fixed-length* lists (`[a,b,c]` / `[a,b,c,d]` / …) must not go through
`matchConsArms` fallthrough: each arm re-peels and the shared-fail DAG explodes
(CPU hang on avh4/elm-color, TSFoster/elm-md5, jweir/elm-iso8601). Dispatch on
`Array.length` first, then peel only arms of that length.
-}
compileListCase : SoleCtors -> Int -> Expr -> Array CaseArm -> Expr
compileListCase sole seed scrutinee arms =
    let
        consArms =
            Array.mapAndKeepJust consArmShape arms

        fixedOnly =
            Array.length consArms >= 2
                && Array.all (\a -> isExactFixedListRest a.rest) consArms
    in
    if fixedOnly then
        compileFixedListByLength sole seed scrutinee arms consArms

    else
        compileListCasePeel sole seed scrutinee arms consArms


isExactFixedListRest : Pattern -> Bool
isExactFixedListRest rest =
    when rest is
        PatList members ->
            Array.isEmpty members

        _ ->
            False


{-| Dispatch on Array.length then peel only arms of that length (1–2 typically).
Avoids multi-arm matchConsArms / general-case peel chains that hang Print.
-}
compileFixedListByLength :
    SoleCtors
    -> Int
    -> Expr
    -> Array CaseArm
    -> Array ConsShape
    -> Expr
compileFixedListByLength sole seed scrutinee arms consArms =
    let
        scrut =
            "ls_" ++ String.fromInt seed

        scope0 =
            occupy scrut emptyScope

        catchAll =
            firstCatchAll arms

        endFail =
            when catchAll is
                Just { name = name, body = body } ->
                    when name is
                        Just n ->
                            let
                                bound =
                                    bindName n scope0
                            in
                            wrapLet bound.name (var scrut)
                                (renameExpr bound.subst body)

                        Nothing ->
                            body

                Nothing ->
                    todo "elm-to-gren: list match fell through"

        -- Distinct lengths only (order of first appearance).
        lengths =
            Array.foldl
                (\arm acc ->
                    let
                        n =
                            Array.length arm.heads
                    in
                    if intInArray n acc then
                        acc

                    else
                        Array.pushLast n acc) [] consArms

        -- Each length branch binds fallthrough as fl_ so peels do not inline the
        -- rest of the dispatch (Print explosion).
        forLength len next =
            let
                ofLen =
                    Array.keepIf (\a -> Array.length a.heads == len) consArms

                failFn =
                    "fl_" ++ String.fromInt (seed + 300 + len)

                nextCall =
                    ExprApplication [ var failFn, ExprUnit ]

                try =
                    Array.indexedFoldr
                        (\j arm nextArm ->
                            let
                                body0 =
                                    when arm.asName is
                                        Just n ->
                                            wrapLet n (var scrut) arm.body

                                        Nothing ->
                                            arm.body

                                armFailFn =
                                    "fl_"
                                        ++ String.fromInt
                                            (seed + 400 + len * 20 + j)

                                armFailCall =
                                    ExprApplication [ var armFailFn, ExprUnit ]

                                peeled =
                                    matchPattern sole
                                        (seed + 200 + len * 1009 + j * 17)
                                        (occupy armFailFn scope0)
                                        (PatList arm.heads) (var scrut) body0
                                        armFailCall
                            in
                            ExprLet
                                { declarations =
                                    [ LetFunction
                                        { name = armFailFn
                                        , arguments = [ PatAll ]
                                        , expression = nextArm
                                        }
                                    ]
                                , expression = peeled
                                }) nextCall ofLen
            in
            ExprLet
                { declarations =
                    [ LetFunction
                        { name = failFn
                        , arguments = [ PatAll ]
                        , expression = next
                        }
                    ]
                , expression =
                    ExprIf
                        { condition =
                            ExprBinop
                                { operator = "=="
                                , left =
                                    ExprApplication
                                        [ ExprVar
                                            { moduleName = Just "Array"
                                            , name = "length"
                                            }
                                        , var scrut
                                        ]
                                , right = ExprInt len
                                }
                        , then_ = try
                        , else_ = nextCall
                        }
                }

        chain =
            Array.foldr forLength endFail lengths

        withEmpty =
            when firstEmptyBody arms is
                Just emptyBody ->
                    ExprIf
                        { condition =
                            ExprBinop
                                { operator = "=="
                                , left =
                                    ExprApplication
                                        [ ExprVar
                                            { moduleName = Just "Array"
                                            , name = "length"
                                            }
                                        , var scrut
                                        ]
                                , right = ExprInt 0
                                }
                        , then_ = emptyBody
                        , else_ = chain
                        }

                Nothing ->
                    chain
    in
    wrapLet scrut scrutinee withEmpty


intInArray : Int -> Array Int -> Bool
intInArray n values =
    Array.foldl (\x acc -> acc || x == n) False values


compileListCasePeel :
    SoleCtors
    -> Int
    -> Expr
    -> Array CaseArm
    -> Array ConsShape
    -> Expr
compileListCasePeel sole seed scrutinee arms consArms =
    let
        scrut =
            "ls_" ++ String.fromInt seed

        headN =
            scrut ++ "_h"

        tailN =
            scrut ++ "_t"

        scope0 =
            emptyScope
                |> occupy scrut
                |> occupy headN
                |> occupy tailN

        catchAll =
            firstCatchAll arms

        nothingBody =
            when firstEmptyBody arms is
                Just body ->
                    body

                Nothing ->
                    when catchAll is
                        Just { name = name, body = body } ->
                            when name is
                                Just n ->
                                    let
                                        bound =
                                            bindName n scope0
                                    in
                                    wrapLet bound.name (var scrut)
                                        (renameExpr bound.subst body)

                                Nothing ->
                                    body

                        Nothing ->
                            todo "elm-to-gren: no empty-list arm"

        nothingBranch =
            { pattern = nothingPat
            , body = nothingBody
            }

        justBranch =
            { pattern = justRecord (PatVar headN) (PatVar tailN)
            , body =
                matchConsArms sole (seed + 1) scope0 (var headN) (var tailN)
                    (var scrut) consArms catchAll
                    (todo "elm-to-gren: list match fell through")
            }
    in
    ExprLet
        { declarations =
            [ LetFunction
                { name = scrut
                , arguments = []
                , expression = scrutinee
                }
            ]
        , expression =
            ExprCase
                { expression = popFirst (var scrut)
                , cases = [ nothingBranch, justBranch ]
                }
        }


type alias ConsShape =
    { heads : Array Pattern
    , rest : Pattern
    , body : Expr
    , asName : Maybe String
    }


consArmShape : CaseArm -> Maybe ConsShape
consArmShape arm =
    let
        asName =
            topAsName arm.pattern
    in
    when stripAs arm.pattern is
        PatAll ->
            Nothing

        PatVar _ ->
            Nothing

        PatList members ->
            if Array.isEmpty members then
                Nothing

            else
                Just
                    { heads = members
                    , rest = PatList []
                    , body = arm.body
                    , asName = asName
                    }

        PatCons _ ->
            consHeadsRest arm.pattern
                |> Maybe.map
                    (\hr ->
                        { heads = hr.heads
                        , rest = hr.rest
                        , body = arm.body
                        , asName = asName
                        })

        _ ->
            Nothing


topAsName : Pattern -> Maybe String
topAsName pattern =
    when pattern is
        PatAs { name = name } ->
            Just name

        _ ->
            Nothing


firstEmptyBody : Array CaseArm -> Maybe Expr
firstEmptyBody arms =
    Array.mapAndKeepJust
        (\arm ->
            when stripAs arm.pattern is
                PatList members ->
                    if Array.isEmpty members then
                        Just arm.body

                    else
                        Nothing

                _ ->
                    Nothing) arms
        |> Array.first


firstCatchAll : Array CaseArm -> Maybe { name : Maybe String, body : Expr }
firstCatchAll arms =
    Array.mapAndKeepJust
        (\arm ->
            when stripAs arm.pattern is
                PatAll ->
                    Just { name = Nothing, body = arm.body }

                PatVar name ->
                    Just { name = Just name, body = arm.body }

                _ ->
                    Nothing) arms
        |> Array.first


{-| Try each cons arm against head/tail already peeled once. Binders stay in patterns.
α-renames binders against `scope` so nested fallthrough arms never shadow.
-}
matchConsArms :
    SoleCtors
    -> Int
    -> Scope
    -> Expr
    -> Expr
    -> Expr
    -> Array ConsShape
    -> Maybe { name : Maybe String, body : Expr }
    -> Expr
    -> Expr
matchConsArms sole seed scope headExpr tailExpr wholeList consArms catchAll fail
        =
    when Array.popFirst consArms is
        Nothing ->
            when catchAll is
                Just { name = name, body = body } ->
                    when name is
                        Just n ->
                            let
                                bound =
                                    bindName n scope
                            in
                            wrapLet bound.name wholeList
                                (renameExpr bound.subst body)

                        Nothing ->
                            body

                Nothing ->
                    fail

        Just { first = arm, rest = more } ->
            let
                -- Outer `as` on the cons arm binds the whole list (e.g. `(q :: _) as qs`).
                asBound =
                    when arm.asName is
                        Just n ->
                            let
                                b =
                                    bindName n scope
                            in
                            { scope = b.scope
                            , subst = b.subst
                            , wrap = \body -> wrapLet b.name wholeList body
                            }

                        Nothing ->
                            { scope = scope
                            , subst = Dict.empty
                            , wrap = \body -> body
                            }

                headsBound =
                    bindPatternList arm.heads asBound.scope

                restBound =
                    bindPattern arm.rest headsBound.scope

                bodyRenamed =
                    arm.body
                        |> renameExpr asBound.subst
                        |> renameExpr headsBound.subst
                        |> renameExpr restBound.subst
                        |> asBound.wrap

                -- Fallthrough sits under this arm's binders for irrefutable heads;
                -- occupy them so the next arm α-renames collisions.
                -- Bind fallthrough as a zero-cost-until-called function so peels
                -- share one fail body (avoids exponential Print blow-up).
                failFn =
                    bindName ("fl_" ++ String.fromInt seed) restBound.scope

                nextFailBody =
                    matchConsArms sole (seed + 17) failFn.scope headExpr
                        tailExpr wholeList more catchAll fail

                nextFailCall =
                    ExprApplication [ var failFn.name, ExprUnit ]

                armExpr =
                    matchHeads sole (seed + 1) failFn.scope headExpr tailExpr
                        headsBound.patterns restBound.pattern bodyRenamed
                        nextFailCall
            in
            ExprLet
                { declarations =
                    [ LetFunction
                        { name = failFn.name
                        , arguments = [ PatAll ]
                        , expression = nextFailBody
                        }
                    ]
                , expression = armExpr
                }


{-| Match remaining heads against current head value and tail list.
Patterns are already α-renamed; scope tracks occupied synthetic names.
-}
matchHeads :
    SoleCtors
    -> Int
    -> Scope
    -> Expr
    -> Expr
    -> Array Pattern
    -> Pattern
    -> Expr
    -> Expr
    -> Expr
matchHeads sole seed scope headExpr tailExpr heads rest body fail =
    when Array.popFirst heads is
        Nothing ->
            -- Should not happen for cons shapes.
            fail

        Just { first = headPat, rest = moreHeads } ->
            if Array.isEmpty moreHeads then
                -- Last head: bind headPat against headExpr, rest against tailExpr.
                finishLastHead sole seed scope headExpr tailExpr headPat rest
                    body fail

            else
                -- More heads: bind this head, peel tail for the rest.
                let
                    tailBase =
                        "lt_" ++ String.fromInt seed

                    tailB =
                        bindName tailBase scope

                    headB =
                        bindName (tailB.name ++ "_h") tailB.scope

                    tailTB =
                        bindName (tailB.name ++ "_t") headB.scope

                    continue =
                        ExprCase
                            { expression = popFirst (var tailB.name)
                            , cases =
                                [ { pattern = nothingPat
                                  , body = fail
                                  }
                                , { pattern =
                                      justRecord (PatVar headB.name)
                                          (PatVar tailTB.name)
                                  , body =
                                      matchHeads sole (seed + 1) tailTB.scope
                                          (var headB.name) (var tailTB.name)
                                          moreHeads rest body fail
                                  }
                                ]
                            }

                    afterHead =
                        wrapLet tailB.name tailExpr continue
                in
                bindIrrefutable sole headPat headExpr afterHead fail


finishLastHead :
    SoleCtors
    -> Int
    -> Scope
    -> Expr
    -> Expr
    -> Pattern
    -> Pattern
    -> Expr
    -> Expr
    -> Expr
finishLastHead sole seed scope headExpr tailExpr headPat rest body fail =
    let
        -- Irrefutable heads: bind with let (never bare `when x is y`).
        -- Nested list heads: peel via matchListShape (bindIrrefutable would leave
        -- PatList in a when-arm → AST_UNPORTED_LIST). Use a seed derived from
        -- pattern size so nested peels do not thrash name `ml_0`.
        withHeadMatch after =
            when headPat is
                PatList members ->
                    matchListShape sole (seed + 50 + Array.length members) scope
                        members (PatList []) headExpr after fail

                PatCons _ ->
                    when consHeadsRest headPat is
                        Just { heads = heads, rest = nestedRest } ->
                            matchListShape sole (seed + 50) scope heads
                                nestedRest headExpr after fail

                        Nothing ->
                            fail

                _ ->
                    bindIrrefutable sole headPat headExpr after fail
    in
    when rest is
        PatVar restName ->
            -- restName already α-renamed in matchConsArms.
            withHeadMatch (wrapLet restName tailExpr body)

        PatAll ->
            withHeadMatch body

        PatList members ->
            if Array.isEmpty members then
                withHeadMatch
                    (ExprCase
                        { expression = popFirst tailExpr
                        , cases =
                            [ { pattern = nothingPat, body = body }
                            , { pattern = PatAll, body = fail }
                            ]
                        })

            else
                fail

        PatAs { pattern = inner, name = asName } ->
            -- rest already renamed; just place.
            wrapLet asName tailExpr
                (finishLastHead sole seed scope headExpr tailExpr headPat inner
                    body fail)

        _ ->
            fail


{-| Bind a pattern against a value without a top-level `when value is <pat>`.

Gren (like Elm) must not case-match bare records as the scrutinee of `when`.
Prefer:

- `let name = value` for vars
- simple `let { a = x, b = y } = value` only when every field is a var/`_`
- nested ctors inside records/tuples: bind the whole record to a temp, then
  peel fields with let/access and `when` for named ctors (let cannot nest
  `Column fn` inside a record pattern)
- `when value is` for refutable custom-type patterns
- sole-constructor named patterns: single arm only (no dead `_`)
-}
bindIrrefutable : SoleCtors -> Pattern -> Expr -> Expr -> Expr -> Expr
bindIrrefutable sole pattern value body fail =
    when pattern is
        PatVar name ->
            wrapLet name value body

        PatAll ->
            body

        PatAs { pattern = inner, name = name } ->
            wrapLet name value
                (bindIrrefutable sole inner (var name) body fail)

        PatRecordBind fields ->
            if Array.all (\f -> isSimpleBind f.pattern) fields then
                wrapDestructure pattern value body

            else
                bindComplexRecord sole fields value body fail

        PatRecord names ->
            wrapDestructure pattern value body

        PatTuple items ->
            -- Tuples print as records; reuse record peel with first/second/...
            let
                labels =
                    tupleBindLabels (Array.length items)

                fields =
                    Array.map2 (\name item -> { name = name, pattern = item })
                        labels items
            in
            bindIrrefutable sole (PatRecordBind fields) value body fail

        PatNamed _ ->
            matchNamed sole pattern value body fail

        _ ->
            matchNamed sole pattern value body fail


{-| Named / other structural patterns: add `_` only when the pattern is refutable.

Irrefutable sole-ctors use `let` destructure — a single-arm `when` (or a dead
`_` on a sole ctor) has crashed Gren (`Map.!`) on packages like tree-with-zipper.
-}
matchNamed : SoleCtors -> Pattern -> Expr -> Expr -> Expr -> Expr
matchNamed sole pattern value body fail =
    if isIrrefutable sole pattern then
        wrapDestructure pattern value body

    else
        ExprCase
            { expression = value
            , cases =
                [ { pattern = pattern, body = body }
                , { pattern = PatAll, body = fail }
                ]
            }


isSimpleBind : Pattern -> Bool
isSimpleBind pattern =
    when pattern is
        PatVar _ ->
            True

        PatAll ->
            True

        _ ->
            False


tupleBindLabels : Int -> Array String
tupleBindLabels count =
    Array.initialize count 0 fieldBindLabel


fieldBindLabel : Int -> String
fieldBindLabel index =
    when index is
        0 ->
            "first"

        1 ->
            "second"

        2 ->
            "third"

        3 ->
            "fourth"

        4 ->
            "fifth"

        5 ->
            "sixth"

        6 ->
            "seventh"

        7 ->
            "eighth"

        _ ->
            "field" ++ String.fromInt (index + 1)


{-| Bind a record with nested patterns: temp = value; then peel each field.
-}
bindComplexRecord :
    SoleCtors
    -> Array { name : String, pattern : Pattern }
    -> Expr
    -> Expr
    -> Expr
    -> Expr
bindComplexRecord sole fields value body fail =
    let
        temp =
            "rb_"
                ++ String.fromInt (Array.length fields)
                ++ "_"
                ++ String.fromInt 0

        peeled =
            Array.foldr
                (\field cont ->
                    bindIrrefutable sole field.pattern
                        (ExprAccess { record = var temp, field = field.name })
                        cont fail) body fields
    in
    wrapLet temp value peeled


wrapDestructure : Pattern -> Expr -> Expr -> Expr
wrapDestructure pattern value body =
    ExprLet
        { declarations =
            [ LetDestructure { pattern = pattern, expression = value } ]
        , expression = body
        }


{-| Irrefutable when any value of the scrutinee type matching this shape needs
no residual `_` arm. Sole-constructor custom types are irrefutable when their
nested argument patterns are irrefutable (package-wide sole-ctor set).
-}
isIrrefutable : SoleCtors -> Pattern -> Bool
isIrrefutable sole pattern =
    when pattern is
        PatVar _ ->
            True

        PatAll ->
            True

        PatAs { pattern = inner } ->
            isIrrefutable sole inner

        PatTuple items ->
            Array.all (isIrrefutable sole) items

        PatRecord _ ->
            -- Shorthand `{ left, parent, right }` is always a pure bind.
            True

        PatRecordBind fields ->
            Array.all (\f -> isIrrefutable sole f.pattern) fields

        PatNamed { ref = ref, arguments = args } ->
            isSoleCtor sole ref && Array.all (isIrrefutable sole) args

        _ ->
            False


isSoleCtor : SoleCtors -> NamedRef -> Bool
isSoleCtor sole ref =
    when ref.moduleName is
        Just moduleName ->
            Dict.member (moduleName ++ "." ++ ref.name) sole
                || Dict.member ref.name sole

        Nothing ->
            Dict.member ref.name sole

-- MAYBE / RESULT WRAPPERS ----------------------------------------------------


tryMaybeListCase :
    SoleCtors
    -> Int
    -> { expression : Expr, cases : Array CaseArm }
    -> Maybe Expr
tryMaybeListCase sole seed caseBlock =
    if not (isMaybeListCase caseBlock.cases) then
        Nothing

    else
        let
            scrut =
                "ms_" ++ String.fromInt seed

            mapped =
                ExprApplication
                    [ ExprVar { moduleName = Just "Maybe", name = "map" }
                    , ExprVar { moduleName = Just "Array", name = "popFirst" }
                    , var scrut
                    ]

            arms =
                Array.indexedMap
                    (\i arm -> rewriteWrapperArm sole (seed + 1 + i) "Just" arm)
                    caseBlock.cases
                    |> Array.mapAndKeepJust (\m -> m)
        in
        if Array.length arms /= Array.length caseBlock.cases then
            Nothing

        else
            Just
                (ExprLet
                    { declarations =
                        [ LetFunction
                            { name = scrut
                            , arguments = []
                            , expression = caseBlock.expression
                            }
                        ]
                    , expression =
                        ExprCase
                            { expression = mapped
                            , cases = arms
                            }
                    })


tryResultListCase :
    SoleCtors
    -> Int
    -> { expression : Expr, cases : Array CaseArm }
    -> Maybe Expr
tryResultListCase sole seed caseBlock =
    if not (isResultListCase caseBlock.cases) then
        Nothing

    else
        let
            scrut =
                "rs_" ++ String.fromInt seed

            mapped =
                ExprApplication
                    [ ExprVar { moduleName = Just "Result", name = "map" }
                    , ExprVar { moduleName = Just "Array", name = "popFirst" }
                    , var scrut
                    ]

            arms =
                Array.indexedMap
                    (\i arm -> rewriteWrapperArm sole (seed + 1 + i) "Ok" arm)
                    caseBlock.cases
                    |> Array.mapAndKeepJust (\m -> m)
        in
        if Array.length arms /= Array.length caseBlock.cases then
            Nothing

        else
            Just
                (ExprLet
                    { declarations =
                        [ LetFunction
                            { name = scrut
                            , arguments = []
                            , expression = caseBlock.expression
                            }
                        ]
                    , expression =
                        ExprCase
                            { expression = mapped
                            , cases = arms
                            }
                    })


isMaybeListCase : Array CaseArm -> Bool
isMaybeListCase arms =
    -- Need at least one Just with a list shape, every arm a Maybe arm, and no
    -- Just x binder that wants the *whole* list (phoenix-socket longPollEvent.messages:
    -- Just [] / Nothing / Just messsages). map popFirst would leave messsages as
    -- Maybe { first, rest } instead of Array.
    Array.any (wrapperHasList "Just") arms
        && Array.all isMaybeArm arms
        && not (Array.any (wrapperHasWholeListBind "Just") arms)


isResultListCase : Array CaseArm -> Bool
isResultListCase arms =
    Array.any (wrapperHasList "Ok") arms
        && Array.all isResultArm arms
        && not (Array.any (wrapperHasWholeListBind "Ok") arms)


{-| `Just xs` / `Ok xs` where `xs` is a bare variable or `_` (binds the full list).
-}
wrapperHasWholeListBind : String -> CaseArm -> Bool
wrapperHasWholeListBind ctor arm =
    when arm.pattern is
        PatNamed { ref = ref, arguments = args } ->
            if ref.name /= ctor then
                False

            else
                when Array.first args is
                    Just (PatVar _) ->
                        True

                    Just PatAll ->
                        True

                    Just (PatAs { pattern = inner }) ->
                        when inner is
                            PatVar _ ->
                                True

                            PatAll ->
                                True

                            _ ->
                                False

                    _ ->
                        False

        _ ->
            False


wrapperHasList : String -> CaseArm -> Bool
wrapperHasList ctor arm =
    when arm.pattern is
        PatNamed { ref = ref, arguments = args } ->
            ref.name == ctor
                && (when Array.first args is
                        Just inner ->
                            patternHasCons inner || isEmptyList inner

                        Nothing ->
                            False)

        _ ->
            False


isMaybeArm : CaseArm -> Bool
isMaybeArm arm =
    when arm.pattern is
        PatAll ->
            True

        PatNamed { ref = ref, arguments = args } ->
            if ref.name == "Nothing" && Array.isEmpty args then
                True

            else if ref.name == "Just" && Array.length args == 1 then
                when Array.first args is
                    Just inner ->
                        isListCaseArm inner || not (patternHasCons inner)

                    Nothing ->
                        False

            else
                False

        _ ->
            False


isResultArm : CaseArm -> Bool
isResultArm arm =
    when arm.pattern is
        PatAll ->
            True

        PatNamed { ref = ref, arguments = args } ->
            if ref.name == "Err" && Array.length args == 1 then
                when Array.first args is
                    Just inner ->
                        not (patternHasCons inner)

                    Nothing ->
                        False

            else if ref.name == "Ok" && Array.length args == 1 then
                when Array.first args is
                    Just inner ->
                        isListCaseArm inner || not (patternHasCons inner)

                    Nothing ->
                        False

            else
                False

        _ ->
            False


{-| After Maybe/Result.map popFirst, Just/Ok payloads are Maybe {first,rest}.
Rewrite inner list pattern under that.
-}
rewriteWrapperArm : SoleCtors -> Int -> String -> CaseArm -> Maybe CaseArm
rewriteWrapperArm sole seed expectCtor arm =
    when arm.pattern is
        PatAll ->
            Just arm

        PatNamed { ref = ref, arguments = args } ->
            if ref.name /= expectCtor then
                Just arm

            else
                when Array.first args is
                    Just inner ->
                        when listShapeToHeadsRest inner is
                            Nothing ->
                                if isEmptyList inner then
                                    Just
                                        { pattern =
                                            PatNamed
                                                { ref = ref
                                                , arguments = [ nothingPat ]
                                                }
                                        , body = arm.body
                                        }

                                else
                                    Just arm

                            Just { heads = heads, rest = rest } ->
                                let
                                    -- Build body that matches Just {first,rest} peels
                                    -- Outer pattern: Just (compiled list match value)
                                    -- Simpler: pattern Just pop, body runs list match on rebuilt...
                                    -- After map popFirst: Just Nothing means [], Just (Just {f,r}) means cons.
                                    -- Actually Maybe.map Array.popFirst:
                                    --   Nothing -> Nothing
                                    --   Just [] -> Just Nothing
                                    --   Just (x::xs) -> Just (Just {first=x, rest=xs})
                                    -- So arms:
                                    --   Just [] -> Just Nothing
                                    --   Just (x::xs) -> Just (Just {first=x, rest=xs})
                                    innerCompiled =
                                        compileListPatternAsPayload sole seed
                                            heads rest arm.body
                                in
                                Just
                                    { pattern =
                                        PatNamed
                                            { ref = ref
                                            , arguments =
                                                [ innerCompiled.pattern ]
                                            }
                                    , body = innerCompiled.body
                                    }

                    Nothing ->
                        Nothing

        _ ->
            Nothing


{-| Compile list shape to a single pattern for under Just/Ok after map popFirst.
Empty list → Nothing. Non-empty → Just { first = h0, rest = ... } with nested peels in body if needed.
-}
compileListPatternAsPayload :
    SoleCtors
    -> Int
    -> Array Pattern
    -> Pattern
    -> Expr
    -> { pattern : Pattern, body : Expr }
compileListPatternAsPayload sole seed heads rest body =
    -- sole unused for payload shapes (patterns sit in Just {…}); kept for API unity.
    compileListPatternAsPayloadScoped seed emptyScope heads rest body


compileListPatternAsPayloadScoped :
    Int
    -> Scope
    -> Array Pattern
    -> Pattern
    -> Expr
    -> { pattern : Pattern, body : Expr }
compileListPatternAsPayloadScoped seed scope heads rest body =
    let
        headsBound =
            bindPatternList heads scope

        restBound =
            bindPattern rest headsBound.scope

        body2 =
            body
                |> renameExpr headsBound.subst
                |> renameExpr restBound.subst
    in
    compileListPatternAsPayloadBound seed restBound.scope headsBound.patterns
        restBound.pattern body2


compileListPatternAsPayloadBound :
    Int
    -> Scope
    -> Array Pattern
    -> Pattern
    -> Expr
    -> { pattern : Pattern, body : Expr }
compileListPatternAsPayloadBound seed scope heads rest body =
    when Array.popFirst heads is
        Nothing ->
            { pattern = nothingPat, body = body }

        Just { first = headPat, rest = more } ->
            if Array.isEmpty more then
                when rest is
                    PatVar restName ->
                        { pattern = justRecord headPat (PatVar restName)
                        , body = body
                        }

                    PatAll ->
                        { pattern = justRecord headPat PatAll
                        , body = body
                        }

                    PatList members ->
                        if Array.isEmpty members then
                            let
                                tmpB =
                                    bindName ("pe_" ++ String.fromInt seed)
                                        scope
                            in
                            { pattern = justRecord headPat (PatVar tmpB.name)
                            , body =
                                ExprCase
                                    { expression = popFirst (var tmpB.name)
                                    , cases =
                                        [ { pattern = nothingPat
                                          , body = body
                                          }
                                        , { pattern = PatAll
                                          , body =
                                              todo
                                                  "elm-to-gren: expected empty rest"
                                          }
                                        ]
                                    }
                            }

                        else
                            { pattern = PatAll, body = body }

                    _ ->
                        { pattern = justRecord headPat PatAll, body = body }

            else
                -- Multi-depth under wrapper: Just { first = h0, rest = t0 }, then peel t0 in body.
                let
                    t0B =
                        bindName ("pw_" ++ String.fromInt seed) scope

                    nested =
                        compileListPatternAsPayloadBound (seed + 1) t0B.scope
                            more rest body

                    body3 =
                        ExprCase
                            { expression = popFirst (var t0B.name)
                            , cases =
                                [ { pattern = nested.pattern
                                  , body = nested.body
                                  }
                                , { pattern = PatAll
                                  , body = todo "elm-to-gren: list peel failed"
                                  }
                                ]
                            }
                in
                { pattern = justRecord headPat (PatVar t0B.name)
                , body = body3
                }

-- CTOR EMBEDDED --------------------------------------------------------------


tryCtorEmbeddedCase :
    SoleCtors
    -> Int
    -> { expression : Expr, cases : Array CaseArm }
    -> Maybe Expr
tryCtorEmbeddedCase sole seed caseBlock =
    if not (isCtorEmbeddedCase caseBlock.cases) then
        Nothing

    else
        let
            -- Ctors whose every arm is a single direct-list column collapse into
            -- one totalized `Array.popFirst` peel (all peers merged in
            -- first-match order); every other ctor keeps the per-arm rewrite.
            collapseNames =
                collapsibleCtorNames caseBlock.cases

            residualCases =
                Array.keepIf
                    (\arm -> not (ctorArmCollapsed collapseNames arm))
                    caseBlock.cases

            collapsedArms =
                Array.mapAndKeepJust
                    (\name ->
                        collapseCtorGroup sole seed caseBlock.expression
                            (firstCatchAll caseBlock.cases) name caseBlock.cases)
                    collapseNames

            -- Precompute so cons arms are dropped whether they appear before or
            -- after the empty peer (`Ctor []` merges empty+cons peels).
            exactEmptyCtors =
                Array.foldl
                    (\arm acc ->
                        if isExactEmptyCtorArm arm then
                            markExactEmptyCtor arm acc

                        else
                            acc) Dict.empty residualCases

            step =
                Array.indexedFoldl
                    (\i arm acc ->
                        when acc is
                            Err _ ->
                                acc

                            Ok arms ->
                                if isCoveredOpenListArm arm exactEmptyCtors then
                                    Ok arms

                                else
                                    when
                                        rewriteCtorArm sole (seed + i * 31)
                                            residualCases arm
                                    is
                                        Nothing ->
                                            Err {}

                                        Just rewritten ->
                                            Ok (Array.pushLast rewritten arms))
                    (Ok []) residualCases
        in
        if Array.length collapsedArms /= Array.length collapseNames then
            -- A flagged group failed to build: bail rather than emit a partial.
            Nothing

        else
            when step is
                Err _ ->
                    Nothing

                Ok residualArms ->
                    Just
                        (ExprCase
                            { expression = caseBlock.expression
                            , cases =
                                Array.flatten [ collapsedArms, residualArms ]
                            })


{-| Ctor names every arm of which is `Ctor … <one direct-list column> …` with
all other columns irrefutable. Such a ctor collapses into a single peeled arm so
all its list peers merge under one `Array.popFirst` dispatch with first-match
order. Nested-ctor / multi-list / literal-column groups are excluded and keep the
per-arm rewrite path.
-}
collapsibleCtorNames : Array CaseArm -> Array String
collapsibleCtorNames arms =
    arms
        |> Array.mapAndKeepJust ctorArmName
        |> distinctNames
        |> Array.keepIf (\name -> ctorGroupCollapsible name arms)


ctorArmName : CaseArm -> Maybe String
ctorArmName arm =
    when arm.pattern is
        PatNamed { ref = ref } ->
            if isReservedMap ref.name then
                Nothing

            else
                Just ref.name

        _ ->
            Nothing


ctorArmRef : CaseArm -> Maybe NamedRef
ctorArmRef arm =
    when arm.pattern is
        PatNamed { ref = ref } ->
            Just ref

        _ ->
            Nothing


ctorArmCollapsed : Array String -> CaseArm -> Bool
ctorArmCollapsed names arm =
    when ctorArmName arm is
        Just name ->
            Array.member name names

        Nothing ->
            False


distinctNames : Array String -> Array String
distinctNames names =
    Array.foldl
        (\name acc ->
            if Array.member name acc then
                acc

            else
                Array.pushLast name acc) [] names


ctorGroupCollapsible : String -> Array CaseArm -> Bool
ctorGroupCollapsible name arms =
    let
        group =
            Array.keepIf (\arm -> ctorArmName arm == Just name) arms
    in
    not (Array.isEmpty group)
        && Array.all cleanCtorListArm group
        && sameListPlacement group


{-| One list column (direct `PatList`/`PatCons`/`PatAs` of those), all other
columns irrefutable — the shape the collapse can peel.
-}
cleanCtorListArm : CaseArm -> Bool
cleanCtorListArm arm =
    when arm.pattern is
        PatNamed { arguments = args } ->
            (Array.length (Array.keepIf isListShape args) == 1)
                && Array.all
                    (\a -> isListShape a || isIrrefutablePat a)
                    args

        _ ->
            False


isIrrefutablePat : Pattern -> Bool
isIrrefutablePat pattern =
    when pattern is
        PatVar _ ->
            True

        PatAll ->
            True

        _ ->
            False


{-| Every arm of the group shares the same arity and list-column index, so one
outer pattern binds the list slot for all of them.
-}
sameListPlacement : Array CaseArm -> Bool
sameListPlacement group =
    let
        placements =
            Array.mapAndKeepJust listColumnIndex group
    in
    when Array.first placements is
        Nothing ->
            False

        Just firstP ->
            (Array.length placements == Array.length group)
                && Array.all (\p -> p == firstP) placements


listColumnIndex : CaseArm -> Maybe { arity : Int, index : Int }
listColumnIndex arm =
    when arm.pattern is
        PatNamed { arguments = args } ->
            when firstListColumn args is
                Just index ->
                    Just { arity = Array.length args, index = index }

                Nothing ->
                    Nothing

        _ ->
            Nothing


firstListColumn : Array Pattern -> Maybe Int
firstListColumn args =
    Array.indexedFoldl
        (\i arg acc ->
            when acc is
                Just _ ->
                    acc

                Nothing ->
                    if isListShape arg then
                        Just i

                    else
                        Nothing) Nothing args


{-| Find sibling arm of the same ctor that binds the whole list as a bare variable.
For example, `Edit newFixes` where newFixes should bind the entire list value.
-}
ctorWholeListVarArm : String -> Array CaseArm -> Maybe { name : String, body : Expr }
ctorWholeListVarArm ctorName arms =
    arms
        |> Array.mapAndKeepJust
            (\arm ->
                when arm.pattern is
                    PatNamed { ref = ref, arguments = args } ->
                        if ref.name /= ctorName then
                            Nothing

                        else
                            when Array.first args is
                                Just (PatVar name) ->
                                    Just { name = name, body = arm.body }

                                _ ->
                                    Nothing

                    _ ->
                        Nothing)
        |> Array.first


{-| Collapse all arms of one ctor into `Ctor … clVar … -> <list peel>`, reusing
the plain list-case totalizer so every peer merges with first-match order. A peel
that runs out of arms falls through to the case's irrefutable arm (never a
reachable `Debug.todo`); the whole scrutinee rebinds a named catch-all. Whole-list
variable bindings (e.g. `Edit newFixes`) provide fallback for non-empty lists.
-}
collapseCtorGroup :
    SoleCtors
    -> Int
    -> Expr
    -> Maybe { name : Maybe String, body : Expr }
    -> String
    -> Array CaseArm
    -> Maybe CaseArm
collapseCtorGroup sole seed scrutinee catchAll ctorName arms =
    let
        indexed =
            arms
                |> Array.indexedMap (\i arm -> { index = i, arm = arm })
                |> Array.keepIf (\e -> ctorArmName e.arm == Just ctorName)
    in
    when Array.first indexed is
        Nothing ->
            Nothing

        Just firstEntry ->
            when listColumnIndex firstEntry.arm is
                Nothing ->
                    Nothing

                Just placement ->
                    when ctorArmRef firstEntry.arm is
                        Nothing ->
                            Nothing

                        Just ref ->
                            let
                                gseed =
                                    seed + firstEntry.index * 1013 + 500

                                listVar =
                                    "cel_" ++ String.fromInt gseed

                                colVar j =
                                    "cec_"
                                        ++ String.fromInt gseed
                                        ++ "_"
                                        ++ String.fromInt j

                                outerArgs =
                                    Array.initialize placement.arity 0
                                        (\j ->
                                            if j == placement.index then
                                                PatVar listVar

                                            else if columnBinds j indexed then
                                                PatVar (colVar j)

                                            else
                                                PatAll)

                                unwrapped =
                                    Array.map
                                        (\e ->
                                            unwrapCtorListArm e.arm
                                                placement.index colVar) indexed

                                -- Non-exhaustive peel falls through to:
                                -- (1) a sibling ctor arm that binds the whole list
                                --     as a variable (e.g., `Edit newFixes`), OR
                                -- (2) the case's irrefutable arm (e.g., `_` catch-all)
                                -- For case (1), bind the variable to the list value
                                -- before running the arm's body.
                                wholeListVarArm =
                                    ctorWholeListVarArm ctorName arms

                                fallthrough =
                                    when wholeListVarArm is
                                        Just entry ->
                                            [ { pattern = PatAll
                                              , body =
                                                    wrapLet entry.name
                                                        (var listVar) entry.body
                                              }
                                            ]

                                        Nothing ->
                                            when catchAll is
                                                Just entry ->
                                                    when entry.name is
                                                        Just n ->
                                                            [ { pattern = PatAll
                                                              , body =
                                                                    wrapLet n scrutinee
                                                                        entry.body
                                                              }
                                                            ]

                                                        Nothing ->
                                                            [ { pattern = PatAll
                                                              , body = entry.body
                                                              }
                                                            ]

                                                Nothing ->
                                                    []
                            in
                            Just
                                { pattern =
                                    PatNamed { ref = ref, arguments = outerArgs }
                                , body =
                                    compileListCase sole gseed (var listVar)
                                        (Array.flatten [ unwrapped, fallthrough ])
                                }


columnBinds : Int -> Array { index : Int, arm : CaseArm } -> Bool
columnBinds j indexed =
    Array.any
        (\e ->
            when e.arm.pattern is
                PatNamed { arguments = args } ->
                    when Array.get j args is
                        Just (PatVar _) ->
                            True

                        _ ->
                            False

                _ ->
                    False) indexed


{-| Drop the ctor wrapper to the bare list pattern; rename the arm's irrefutable
non-list column binders onto the shared outer column vars.
-}
unwrapCtorListArm : CaseArm -> Int -> (Int -> String) -> CaseArm
unwrapCtorListArm arm listCol colVar =
    when arm.pattern is
        PatNamed { arguments = args } ->
            let
                subst =
                    Array.indexedFoldl
                        (\j arg acc ->
                            if j == listCol then
                                acc

                            else
                                when arg is
                                    PatVar name ->
                                        Dict.set name (colVar j) acc

                                    _ ->
                                        acc) Dict.empty args
            in
            { pattern =
                Array.get listCol args
                    |> Maybe.withDefault PatAll
            , body = renameExpr subst arm.body
            }

        _ ->
            { pattern = PatAll, body = arm.body }


isExactEmptyCtorArm : CaseArm -> Bool
isExactEmptyCtorArm arm =
    when arm.pattern is
        PatNamed { arguments = args } ->
            nestedArgIsEmptyList args

        _ ->
            False


markExactEmptyCtor : CaseArm -> Dict String {} -> Dict String {}
markExactEmptyCtor arm seen =
    when arm.pattern is
        PatNamed { ref = ref } ->
            Dict.set ref.name {} seen

        _ ->
            seen


{-| True when this arm is covered by a prior exact-empty arm for the same ctor:
`Ctor _` / `Ctor xs`, or `Ctor (x :: xs)` (possibly nested) once empty+cons merge.
-}
isCoveredOpenListArm : CaseArm -> Dict String {} -> Bool
isCoveredOpenListArm arm exactEmptyCtors =
    when arm.pattern is
        PatNamed { ref = ref, arguments = args } ->
            if not (Dict.member ref.name exactEmptyCtors) then
                False

            else
                when Array.first args is
                    Just PatAll ->
                        True

                    Just (PatVar _) ->
                        True

                    Just _ ->
                        -- Cons / nested cons peer merged into the empty arm peel.
                        when nestedListShape args is
                            Just { heads = heads } ->
                                not (Array.isEmpty heads)

                            Nothing ->
                                False

                    Nothing ->
                        False

        _ ->
            False


isCtorEmbeddedCase : Array CaseArm -> Bool
isCtorEmbeddedCase arms =
    Array.any armHasCtorList arms
        && Array.all ctorArmOk arms
        && not (ctorShadows arms)


isReservedMap : String -> Bool
isReservedMap name =
    name == "Just" || name == "Nothing" || name == "Ok" || name == "Err"


armHasCtorList : CaseArm -> Bool
armHasCtorList arm =
    when arm.pattern is
        PatNamed { ref = ref, arguments = args } ->
            not (isReservedMap ref.name)
                && Array.any (\a -> patternHasCons a || isEmptyList a) args

        _ ->
            False


ctorArmOk : CaseArm -> Bool
ctorArmOk arm =
    when arm.pattern is
        PatAll ->
            True

        PatNamed { ref = ref, arguments = args } ->
            not (isReservedMap ref.name)
                && Array.all nestedCtorArgOk args

        _ ->
            False


{-| Args may be list-shaped, plain, or nested single-arg ctors that themselves
embed lists (`Operate (Batch (x :: xs))`).
-}
nestedCtorArgOk : Pattern -> Bool
nestedCtorArgOk arg =
    isListCaseArm arg
        || not (patternHasCons arg)
        || nestedNamedListOk arg


nestedNamedListOk : Pattern -> Bool
nestedNamedListOk pattern =
    when pattern is
        PatNamed { ref = ref, arguments = args } ->
            not (isReservedMap ref.name)
                && Array.all nestedCtorArgOk args

        PatAs { pattern = inner } ->
            nestedNamedListOk inner

        _ ->
            False


ctorShadows : Array CaseArm -> Bool
ctorShadows arms =
    let
        unconsNames =
            arms
                |> Array.mapAndKeepJust
                    (\arm ->
                        when arm.pattern is
                            PatNamed { ref = ref, arguments = args } ->
                                if Array.any patternHasCons args then
                                    Just ref.name

                                else
                                    Nothing

                            _ ->
                                Nothing)

        catchNames =
            arms
                |> Array.mapAndKeepJust
                    (\arm ->
                        when arm.pattern is
                            PatNamed { ref = ref, arguments = args } ->
                                when Array.first args is
                                    Just (PatVar _) ->
                                        Just ref.name

                                    Just PatAll ->
                                        Just ref.name

                                    _ ->
                                        Nothing

                            _ ->
                                Nothing)
    in
    Array.any (\n -> Array.member n catchNames) unconsNames


rewriteCtorArm : SoleCtors -> Int -> Array CaseArm -> CaseArm -> Maybe CaseArm
rewriteCtorArm sole seed allArms arm =
    when arm.pattern is
        PatAll ->
            Just arm

        PatNamed { ref = ref, arguments = args } ->
            let
                emptyFb =
                    ctorEmptyFallback ref.name allArms

                consPeer =
                    ctorConsListPeer ref.name allArms

                openListArm =
                    ctorOpenListFallbackArm ref.name allArms

                nonEmptyFb =
                    when openListArm is
                        Just entry ->
                            when entry.varName is
                                Just varName ->
                                    -- Body references the whole list as a variable;
                                    -- will be bound to the actual list value in
                                    -- peelBoundListMerged
                                    entry.body

                                Nothing ->
                                    entry.body

                        Nothing ->
                            todo "elm-to-gren: expected empty list"

                prepared =
                    Array.indexedMap (\i arg -> prepareCtorArg (seed + i) arg)
                        args
            in
            if Array.any .failed prepared then
                Nothing

            else
                Just
                    { pattern =
                        PatNamed
                            { ref = ref
                            , arguments = Array.map .pattern prepared
                            }
                    , body =
                        Array.foldl
                            (\item body ->
                                Array.foldl
                                    (\bind inner ->
                                        peelBoundListMergedWithFallback sole bind
                                            body emptyFb nonEmptyFb consPeer
                                            openListArm) body
                                    item.listBinds) arm.body prepared
                    }

        _ ->
            Nothing


{-| Body and var name of a later arm `Ctor _` / `Ctor xs` — used when `Ctor []`
sees a non-empty list. When the arm binds the whole list as a variable, return
the name so it can be bound to the actual list value.
-}
ctorOpenListFallbackArm :
    String
    -> Array CaseArm
    -> Maybe { varName : Maybe String, body : Expr }
ctorOpenListFallbackArm ctorName arms =
    arms
        |> Array.mapAndKeepJust
            (\arm ->
                when arm.pattern is
                    PatNamed { ref = ref, arguments = args } ->
                        if ref.name /= ctorName then
                            Nothing

                        else
                            when Array.first args is
                                Just PatAll ->
                                    Just { varName = Nothing, body = arm.body }

                                Just (PatVar name) ->
                                    Just { varName = Just name, body = arm.body }

                                _ ->
                                    Nothing

                    _ ->
                        Nothing)
        |> Array.first


{-| Body of a later arm `Ctor _` / `Ctor xs` — used when `Ctor []` sees a non-empty list.
-}
ctorOpenListFallback : String -> Array CaseArm -> Maybe Expr
ctorOpenListFallback ctorName arms =
    ctorOpenListFallbackArm ctorName arms
        |> Maybe.map .body


{-| Peer arm `Ctor … (x :: xs)` (possibly nested under single-arg ctors) for
merging empty+cons list peels under the same outer constructor.
-}
ctorConsListPeer :
    String
    -> Array CaseArm
    -> Maybe { heads : Array Pattern, rest : Pattern, body : Expr }
ctorConsListPeer ctorName arms =
    arms
        |> Array.mapAndKeepJust
            (\arm ->
                when arm.pattern is
                    PatNamed { ref = ref, arguments = args } ->
                        if ref.name /= ctorName then
                            Nothing

                        else
                            when nestedListShape args is
                                Just { heads = heads, rest = rest } ->
                                    if
                                        Array.isEmpty heads && isEmptyList rest
                                    then
                                        Nothing

                                    else
                                        Just
                                            { heads = heads
                                            , rest = rest
                                            , body = arm.body
                                            }

                                Nothing ->
                                    Nothing

                    _ ->
                        Nothing)
        |> Array.first


{-| Walk single-arg named chains to the embedded list shape.
`Batch (x :: xs)` / `Batch []` / `Operate (Batch (x :: xs))`.
-}
nestedListShape :
    Array Pattern
    -> Maybe { heads : Array Pattern, rest : Pattern }
nestedListShape args =
    when Array.first args is
        Nothing ->
            Nothing

        Just arg ->
            when listShapeToHeadsRest arg is
                Just shape ->
                    Just shape

                Nothing ->
                    if isEmptyList arg then
                        Just { heads = [], rest = PatList [] }

                    else
                        when arg is
                            PatNamed { arguments = inner } ->
                                nestedListShape inner

                            PatAs { pattern = inner } ->
                                nestedListShape [ inner ]

                            _ ->
                                Nothing


ctorEmptyFallback : String -> Array CaseArm -> Expr
ctorEmptyFallback ctorName arms =
    arms
        |> Array.mapAndKeepJust
            (\arm ->
                when arm.pattern is
                    PatNamed { ref = ref, arguments = args } ->
                        if ref.name /= ctorName then
                            Nothing

                        else if nestedArgIsEmptyList args then
                            Just arm.body

                        else
                            Nothing

                    _ ->
                        Nothing)
        |> Array.first
        |> Maybe.withDefault (todo "elm-to-gren: expected empty list arm")


nestedArgIsEmptyList : Array Pattern -> Bool
nestedArgIsEmptyList args =
    when Array.first args is
        Nothing ->
            False

        Just arg ->
            if isEmptyList arg then
                True

            else
                when arg is
                    PatNamed { arguments = inner } ->
                        nestedArgIsEmptyList inner

                    PatAs { pattern = inner } ->
                        isEmptyList inner

                    _ ->
                        False


type alias ListBind =
    { listName : String
    , heads : Array Pattern
    , rest : Pattern
    , exactEmpty : Bool
    }


type alias CtorArgPrep =
    { pattern : Pattern
    , listBinds : Array ListBind
    , failed : Bool
    }


prepareCtorArg : Int -> Pattern -> CtorArgPrep
prepareCtorArg seed arg =
    let
        listName =
            "cl_" ++ String.fromInt seed
    in
    when listShapeToHeadsRest arg is
        Just { heads = heads, rest = rest } ->
            { pattern = PatVar listName
            , listBinds =
                [ { listName = listName
                  , heads = heads
                  , rest = rest
                  , exactEmpty = False
                  }
                ]
            , failed = False
            }

        Nothing ->
            if isEmptyList arg then
                { pattern = PatVar listName
                , listBinds =
                    [ { listName = listName
                      , heads = []
                      , rest = PatList []
                      , exactEmpty = True
                      }
                    ]
                , failed = False
                }

            else
                when arg is
                    PatNamed { ref = ref, arguments = innerArgs } ->
                        if
                            Array.any (\a -> patternHasCons a || isEmptyList a)
                                innerArgs
                        then
                            let
                                prepared =
                                    Array.indexedMap
                                        (\i inner ->
                                            prepareCtorArg (seed * 37 + i + 1)
                                                inner) innerArgs
                            in
                            if Array.any .failed prepared then
                                { pattern = arg
                                , listBinds = []
                                , failed = True
                                }

                            else
                                { pattern =
                                    PatNamed
                                        { ref = ref
                                        , arguments =
                                            Array.map .pattern prepared
                                        }
                                , listBinds =
                                    Array.foldl
                                        (\p acc ->
                                            Array.foldl Array.pushLast acc
                                                p.listBinds) [] prepared
                                , failed = False
                                }

                        else
                            { pattern = arg, listBinds = [], failed = False }

                    PatAs { pattern = inner, name = name } ->
                        let
                            prepared =
                                prepareCtorArg (seed + 1) inner
                        in
                        { pattern =
                            PatAs { pattern = prepared.pattern, name = name }
                        , listBinds = prepared.listBinds
                        , failed = prepared.failed
                        }

                    _ ->
                        if patternHasCons arg then
                            { pattern = arg, listBinds = [], failed = True }

                        else
                            { pattern = arg, listBinds = [], failed = False }


{-| Peel a list bound under a ctor arm, with optional fallback info.
When this is the exact-empty arm and a cons peer exists, merge into one
`popFirst` dispatch. When fallback arm binds the whole list as a variable,
bind it before running the body.
-}
peelBoundListMergedWithFallback :
    SoleCtors
    -> ListBind
    -> Expr
    -> Expr
    -> Expr
    -> Maybe { heads : Array Pattern, rest : Pattern, body : Expr }
    -> Maybe { varName : Maybe String, body : Expr }
    -> Expr
peelBoundListMergedWithFallback sole bind body emptyFb nonEmptyFb consPeer
        fallbackArm =
    if bind.exactEmpty then
        when consPeer is
            Just peer ->
                -- Empty + cons siblings: one peel, both bodies.
                compileListCaseOnVar sole 0 (occupy bind.listName emptyScope)
                    bind.listName peer.heads peer.rest peer.body body

            Nothing ->
                -- Peel empty case, and use fallback for non-empty.
                -- If fallback arm has a variable binding, bind it to the list value.
                let
                    actualNonEmptyFb =
                        when fallbackArm is
                            Just entry ->
                                when entry.varName is
                                    Just varName ->
                                        wrapLet varName (var bind.listName)
                                            entry.body

                                    Nothing ->
                                        entry.body

                            Nothing ->
                                nonEmptyFb
                in
                peelBoundList sole bind body emptyFb actualNonEmptyFb

    else
        peelBoundList sole bind body emptyFb nonEmptyFb


{-| Peel a list bound under a ctor arm. When this is the exact-empty arm and a
cons peer exists (`Ctor []` + `Ctor (x :: xs)`, possibly nested), merge into one
`popFirst` dispatch so heads bind correctly and the cons arm can be dropped.
-}
peelBoundListMerged :
    SoleCtors
    -> ListBind
    -> Expr
    -> Expr
    -> Expr
    -> Maybe { heads : Array Pattern, rest : Pattern, body : Expr }
    -> Expr
peelBoundListMerged sole bind body emptyFb nonEmptyFb consPeer =
    if bind.exactEmpty then
        when consPeer is
            Just peer ->
                -- Empty + cons siblings: one peel, both bodies.
                compileListCaseOnVar sole 0 (occupy bind.listName emptyScope)
                    bind.listName peer.heads peer.rest peer.body body

            Nothing ->
                peelBoundList sole bind body emptyFb nonEmptyFb

    else
        peelBoundList sole bind body emptyFb nonEmptyFb


peelBoundList :
    SoleCtors
    -> ListBind
    -> Expr
    -> Expr
    -> Expr
    -> Expr
peelBoundList sole bind body emptyFb nonEmptyFb =
    if bind.exactEmpty then
        -- Object [] vs Object _: empty → this arm body; non-empty → open-list arm body.
        ExprCase
            { expression = popFirst (var bind.listName)
            , cases =
                [ { pattern = nothingPat, body = body }
                , { pattern = PatAll, body = nonEmptyFb }
                ]
            }

    else
        -- Reuse list case compiler on the bound list name.
        compileListCaseOnVar sole 0 (occupy bind.listName emptyScope)
            bind.listName bind.heads bind.rest body emptyFb


{-| Match heads/rest against an already-bound list variable.
Binders for heads and open rest live in `Just { first = …, rest = … }` patterns.
-}
compileListCaseOnVar :
    SoleCtors
    -> Int
    -> Scope
    -> String
    -> Array Pattern
    -> Pattern
    -> Expr
    -> Expr
    -> Expr
compileListCaseOnVar sole seed scope listName heads rest body fail =
    let
        headsBound =
            bindPatternList heads scope

        restBound =
            bindPattern rest headsBound.scope

        body2 =
            body
                |> renameExpr headsBound.subst
                |> renameExpr restBound.subst
    in
    compileListCaseOnVarBound seed restBound.scope listName headsBound.patterns
        restBound.pattern body2 fail


compileListCaseOnVarBound :
    Int
    -> Scope
    -> String
    -> Array Pattern
    -> Pattern
    -> Expr
    -> Expr
    -> Expr
compileListCaseOnVarBound seed scope listName heads rest body fail =
    when Array.popFirst heads is
        Nothing ->
            fail

        Just { first = headPat, rest = more } ->
            if Array.isEmpty more then
                when rest is
                    PatVar restName ->
                        ExprCase
                            { expression = popFirst (var listName)
                            , cases =
                                [ { pattern = nothingPat
                                  , body = fail
                                  }
                                , { pattern =
                                      justRecord headPat (PatVar restName)
                                  , body = body
                                  }
                                ]
                            }

                    PatAll ->
                        ExprCase
                            { expression = popFirst (var listName)
                            , cases =
                                [ { pattern = nothingPat
                                  , body = fail
                                  }
                                , { pattern = justRecord headPat PatAll
                                  , body = body
                                  }
                                ]
                            }

                    PatList members ->
                        if Array.isEmpty members then
                            let
                                tmpB =
                                    bindName ("er_" ++ String.fromInt seed)
                                        scope
                            in
                            ExprCase
                                { expression = popFirst (var listName)
                                , cases =
                                    [ { pattern = nothingPat
                                      , body = fail
                                      }
                                    , { pattern =
                                          justRecord headPat (PatVar tmpB.name)
                                      , body =
                                          ExprCase
                                              { expression =
                                                  popFirst (var tmpB.name)
                                              , cases =
                                                  [ { pattern = nothingPat
                                                    , body = body
                                                    }
                                                  , { pattern = PatAll
                                                    , body = fail
                                                    }
                                                  ]
                                              }
                                      }
                                    ]
                                }

                        else
                            fail

                    _ ->
                        fail

            else
                let
                    tmpB =
                        bindName ("lt_" ++ String.fromInt seed) scope
                in
                ExprCase
                    { expression = popFirst (var listName)
                    , cases =
                        [ { pattern = nothingPat
                          , body = fail
                          }
                        , { pattern = justRecord headPat (PatVar tmpB.name)
                          , body =
                              compileListCaseOnVarBound (seed + 1) tmpB.scope
                                  tmpB.name more rest body fail
                          }
                        ]
                    }

-- TUPLE LIST -----------------------------------------------------------------


tryTupleListCase :
    SoleCtors
    -> Int
    -> { expression : Expr, cases : Array CaseArm }
    -> Maybe Expr
tryTupleListCase sole seed caseBlock =
    when caseBlock.expression is
        ExprTuple components ->
            let
                arity =
                    Array.length components
            in
            if not (isTupleList arity caseBlock.cases) then
                Nothing

            else
                let
                    listCols =
                        Array.initialize arity 0
                            (\i -> tupleColIsList i caseBlock.cases)

                    wrapped =
                        Array.indexedMap
                            (\i c ->
                                if Array.get i listCols == Just True then
                                    popFirst c

                                else
                                    c) components

                    arms =
                        Array.indexedMap
                            (\i arm ->
                                rewriteTupleArm sole (seed + i * 13) listCols
                                    arm) caseBlock.cases
                            |> Array.mapAndKeepJust (\m -> m)
                in
                if Array.length arms /= Array.length caseBlock.cases then
                    Nothing

                else
                    -- Never `when { first, second } is` with nested ctors:
                    -- Gren 0.6.6 crashes (Map.!) on that shape (elm-deque).
                    Just (desugarTupleListCase sole (seed + 7) wrapped arms)

        _ ->
            Nothing


{-| Bind each tuple column, then nest per-arm `when` via `matchNamed`.
-}
desugarTupleListCase : SoleCtors -> Int -> Array Expr -> Array CaseArm -> Expr
desugarTupleListCase sole seed components arms =
    let
        temps =
            Array.initialize (Array.length components) 0
                (\i -> "tc_" ++ String.fromInt seed ++ "_" ++ String.fromInt i)

        decls =
            Array.indexedMap
                (\i temp ->
                    LetDestructure
                        { pattern = PatVar temp
                        , expression =
                            when Array.get i components is
                                Just c ->
                                    c

                                Nothing ->
                                    ExprUnit
                        }) temps

        chain =
            chainTupleArms sole (seed + 1) temps arms
                (todo "elm-to-gren: tuple list fell through")
    in
    ExprLet { declarations = decls, expression = chain }


chainTupleArms :
    SoleCtors
    -> Int
    -> Array String
    -> Array CaseArm
    -> Expr
    -> Expr
chainTupleArms sole seed temps arms fail =
    when Array.popFirst arms is
        Nothing ->
            fail

        Just { first = arm, rest = more } ->
            let
                failName =
                    "tf_" ++ String.fromInt seed

                next =
                    chainTupleArms sole (seed + 1) temps more fail

                matched =
                    matchTupleArmColumns sole temps arm.pattern arm.body
                        (ExprApplication [ var failName, ExprUnit ])
            in
            ExprLet
                { declarations =
                    [ LetFunction
                        { name = failName
                        , arguments = [ PatAll ]
                        , expression = next
                        }
                    ]
                , expression = matched
                }


matchTupleArmColumns :
    SoleCtors
    -> Array String
    -> Pattern
    -> Expr
    -> Expr
    -> Expr
matchTupleArmColumns sole temps pattern body fail =
    when pattern is
        PatAll ->
            body

        PatTuple items ->
            let
                pairs =
                    Array.indexedMap (\i p -> { index = i, pattern = p }) items
            in
            Array.foldr
                (\pair cont ->
                    when Array.get pair.index temps is
                        Just temp ->
                            matchNamed sole pair.pattern (var temp) cont fail

                        Nothing ->
                            fail) body pairs

        PatAs { pattern = inner } ->
            matchTupleArmColumns sole temps inner body fail

        _ ->
            fail


isTupleList : Int -> Array CaseArm -> Bool
isTupleList arity arms =
    -- Pure list shapes (`[]`, `[x]`) count — not only `::` (deque first/last).
    Array.any (tupleHasListShape arity) arms
        && Array.all (tupleArmOkArity arity) arms


tupleArmOkArity : Int -> CaseArm -> Bool
tupleArmOkArity arity arm =
    when arm.pattern is
        PatAll ->
            True

        PatTuple items ->
            Array.length items == arity
                && Array.all (\p -> isListCaseArm p || not (patternHasCons p))
                    items

        _ ->
            False


{-| True when a tuple arm embeds a list/cons pattern that needs popFirst.
-}
tupleHasListShape : Int -> CaseArm -> Bool
tupleHasListShape _ arm =
    when arm.pattern is
        PatTuple items ->
            Array.any (\p -> isListShape p || patternHasCons p) items

        _ ->
            False


tupleColIsList : Int -> Array CaseArm -> Bool
tupleColIsList index arms =
    Array.any
        (\arm ->
            when arm.pattern is
                PatTuple items ->
                    when Array.get index items is
                        Just p ->
                            isListShape p || patternHasCons p

                        Nothing ->
                            False

                _ ->
                    False) arms


rewriteTupleArm : SoleCtors -> Int -> Array Bool -> CaseArm -> Maybe CaseArm
rewriteTupleArm sole seed listCols arm =
    when arm.pattern is
        PatAll ->
            Just arm

        PatTuple items ->
            let
                pats =
                    Array.indexedMap
                        (\i p ->
                            when Array.get i listCols is
                                Just True ->
                                    -- Under outer popFirst, pattern is Maybe {first,rest}
                                    payloadPattern sole (seed + i) p

                                _ ->
                                    Just p) items
                        |> Array.mapAndKeepJust (\m -> m)
            in
            if Array.length pats /= Array.length items then
                Nothing

            else
                Just { pattern = PatTuple pats, body = arm.body }

        _ ->
            Nothing


payloadPattern : SoleCtors -> Int -> Pattern -> Maybe Pattern
payloadPattern sole seed pattern =
    when listShapeToHeadsRest pattern is
        Nothing ->
            if isEmptyList pattern then
                Just nothingPat

            else
                Just pattern

        Just { heads = heads, rest = rest } ->
            Just
                (compileListPatternAsPayload sole seed heads rest
                    (ExprUnit)).pattern

-- CONS IN ARGS ---------------------------------------------------------------


rewriteConsArgs :
    SoleCtors
    -> Int
    -> Array Pattern
    -> Expr
    -> { arguments : Array Pattern, expression : Expr }
rewriteConsArgs sole seed arguments body =
    Array.indexedFoldl
        (\index arg current ->
            if patternHasCons arg || isEmptyList arg then
                when listShapeToHeadsRest arg is
                    Just { heads = heads, rest = rest } ->
                        let
                            listName =
                                "al_"
                                    ++ String.fromInt seed
                                    ++ "_"
                                    ++ String.fromInt index

                            -- Occupy prior arg binders so peels cannot shadow them.
                            scope0 =
                                Array.foldl
                                    (\p s -> occupyAll (patternBinders p) s)
                                    emptyScope current.arguments
                                    |> occupy listName

                            peeled =
                                compileListCaseOnVar sole 0 scope0 listName
                                    heads rest current.expression
                                    (todo "elm-to-gren: arg list mismatch")
                        in
                        { arguments =
                            Array.pushLast (PatVar listName) current.arguments
                        , expression = peeled
                        }

                    Nothing ->
                        if isEmptyList arg then
                            let
                                listName =
                                    "al_"
                                        ++ String.fromInt seed
                                        ++ "_"
                                        ++ String.fromInt index

                                peeled =
                                    ExprCase
                                        { expression = popFirst (var listName)
                                        , cases =
                                            [ { pattern = nothingPat
                                              , body = current.expression
                                              }
                                            , { pattern = PatAll
                                              , body =
                                                  todo
                                                      "elm-to-gren: expected empty arg"
                                              }
                                            ]
                                        }
                            in
                            { arguments =
                                Array.pushLast (PatVar listName)
                                    current.arguments
                            , expression = peeled
                            }

                        else
                            { arguments = Array.pushLast arg current.arguments
                            , expression = current.expression
                            }

            else
                { arguments = Array.pushLast arg current.arguments
                , expression = current.expression
                }) { arguments = [], expression = body } arguments

-- PATTERN HELPERS ------------------------------------------------------------


consHeadsRest : Pattern -> Maybe { heads : Array Pattern, rest : Pattern }
consHeadsRest pattern =
    when pattern is
        PatCons { head = head, tail = tail } ->
            when consHeadsRest tail is
                Just chain ->
                    Just
                        { heads = Array.pushFirst head chain.heads
                        , rest = chain.rest
                        }

                Nothing ->
                    Just { heads = [ head ], rest = tail }

        PatAs { pattern = inner } ->
            consHeadsRest inner

        _ ->
            Nothing


listShapeToHeadsRest :
    Pattern
    -> Maybe { heads : Array Pattern, rest : Pattern }
listShapeToHeadsRest pattern =
    when pattern is
        PatList members ->
            if Array.isEmpty members then
                Nothing

            else
                Just { heads = members, rest = PatList [] }

        PatCons _ ->
            consHeadsRest pattern

        PatAs { pattern = inner } ->
            listShapeToHeadsRest inner

        _ ->
            Nothing


stripAs : Pattern -> Pattern
stripAs pattern =
    when pattern is
        PatAs { pattern = inner } ->
            stripAs inner

        _ ->
            pattern


isEmptyList : Pattern -> Bool
isEmptyList pattern =
    when pattern is
        PatList members ->
            Array.isEmpty members

        PatAs { pattern = inner } ->
            isEmptyList inner

        _ ->
            False


justRecord : Pattern -> Pattern -> Pattern
justRecord firstPat restPat =
    PatNamed
        { ref = { moduleName = Nothing, name = "Just" }
        , arguments =
            [ PatRecordBind
                [ { name = "first", pattern = firstPat }
                , { name = "rest", pattern = restPat }
                ]
            ]
        }


nothingPat : Pattern
nothingPat =
    PatNamed
        { ref = { moduleName = Nothing, name = "Nothing" }
        , arguments = []
        }


popFirst : Expr -> Expr
popFirst scrut =
    ExprApplication
        [ ExprVar { moduleName = Just "Array", name = "popFirst" }
        , scrut
        ]


var : String -> Expr
var name =
    ExprVar { moduleName = Nothing, name = name }


wrapLet : String -> Expr -> Expr -> Expr
wrapLet name value body =
    ExprLet
        { declarations =
            [ LetFunction
                { name = name
                , arguments = []
                , expression = value
                }
            ]
        , expression = body
        }


todo : String -> Expr
todo message =
    ExprApplication
        [ ExprVar { moduleName = Just "Debug", name = "todo" }
        , ExprString message
        ]

-- UNPORTED SCAN --------------------------------------------------------------


declarationHasUnported : Declaration -> Bool
declarationHasUnported declaration =
    when declaration is
        DeclFunction fn ->
            Array.any patternHasUnportedList fn.arguments
                || exprHasUnported fn.expression

        DeclDestructure { pattern = pattern, expression = expression } ->
            patternHasUnportedList pattern || exprHasUnported expression

        _ ->
            False


exprHasUnported : Expr -> Bool
exprHasUnported expr =
    let
        here =
            when expr is
                ExprCase { cases = arms } ->
                    Array.any (\a -> patternHasUnportedList a.pattern) arms

                ExprLambda { arguments = arguments } ->
                    Array.any patternHasUnportedList arguments

                ExprLet { declarations = declarations } ->
                    Array.any letPatternsUnported declarations

                _ ->
                    False
    in
    if here then
        True

    else
        -- fold short-circuits poorly; any-child via fold flag.
        Walk.foldExprChildren
            (\child acc ->
                if acc then
                    True

                else
                    exprHasUnported child) False expr


letPatternsUnported : LetDecl -> Bool
letPatternsUnported declaration =
    when declaration is
        LetFunction fn ->
            Array.any patternHasUnportedList fn.arguments

        LetDestructure { pattern = pattern } ->
            patternHasUnportedList pattern


{-| Residual patterns Print cannot emit as valid Gren.

Gren accepts fixed array patterns (`[a, b, c]`, even nested). It does **not**
accept Elm cons patterns (`x :: xs`); those must be peeled to `Array.popFirst`.
-}
patternHasUnportedList : Pattern -> Bool
patternHasUnportedList pattern =
    when pattern is
        PatCons _ ->
            True

        PatList items ->
            -- Fixed lists print as Gren array patterns; only dig for nested cons.
            Array.any patternHasUnportedList items

        PatTuple items ->
            Array.any patternHasUnportedList items

        PatNamed { arguments = args } ->
            Array.any patternHasUnportedList args

        PatRecordBind fields ->
            Array.any (\f -> patternHasUnportedList f.pattern) fields

        PatAs { pattern = inner } ->
            patternHasUnportedList inner

        _ ->
            False


patternHasCons : Pattern -> Bool
patternHasCons pattern =
    when pattern is
        PatCons _ ->
            True

        PatTuple items ->
            Array.any patternHasCons items

        PatList items ->
            Array.any patternHasCons items

        PatNamed { arguments = args } ->
            Array.any patternHasCons args

        PatRecordBind fields ->
            Array.any (\f -> patternHasCons f.pattern) fields

        PatAs { pattern = inner } ->
            patternHasCons inner

        _ ->
            False
