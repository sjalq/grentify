module MappingSemanticsTest exposing (tests)

{-| P2 differential table.

Each row exercises LCG-seeded inputs and compares an actual behavior (a Compat
adapter body, replicated here, or Gren's native operator) against an
Elm-semantics reference.

Laws under test:

  - `String.append a b == a ++ b` (Elm order). Gren's `String.append` is
    argument-flipped (`append a b == b ++ a`), so the Compat adapter restores
    Elm order with `++`.
  - `Array.append a b == a ++ b` (Elm order). Gren's `Array.append` is
    argument-flipped as well; the Compat adapter restores Elm order with `++`.
  - `n // 0 == 0`. Elm and Gren agree here, so no adapter is required.
  - `Array.get i` / `Array.set i` return Nothing / leave the array unaltered
    for ANY out-of-range i in Elm. Gren counts negative indices from the end,
    so the Compat adapters guard `i < 0`.
  - `Array.slice` treats negative indices identically in Elm and Gren
    (count from the end, clamp, empty when crossed) — parity asserted, no
    adapter.

-}

import Array exposing (Array)
import Char
import Dict exposing (Dict)
import Math
import Set exposing (Set)
import String


type alias TestResult =
    { name : String
    , passed : Bool
    , details : String
    }


tests : Array TestResult
tests =
    [ stringAppendPreservesElmOrder
    , arrayAppendPreservesElmOrder
    , intDivideByZeroIsZero
    , arrayGetMatchesElmBounds
    , arraySetMatchesElmBounds
    , arraySliceParity
    , mathModByNonNegative
    , mathRemainderByPreservesSign
    , charToLowerMatchesElm
    , charToUpperMatchesElm
    , charToLocaleLowerMatchesElm
    , charToLocaleUpperMatchesElm
    , stringConcatMatchesElm
    , stringUnconsMatchesElm
    , arrayInitializeMatchesElm
    , listTailMatchesElm
    , listPartitionMatchesElm
    , dictToListMatchesElm
    , dictFromListMatchesElm
    , dictPartitionMatchesElm
    , setPartitionMatchesElm
    ]



-- COMPAT ADAPTER BODIES (replicated from Mapping.Adapter)


{-| Mirrors `ElmToGren.Compat.String.append`: `a ++ b` restores Elm order.
-}
compatStringAppend : String -> String -> String
compatStringAppend lhs rhs =
    lhs ++ rhs


{-| Mirrors `ElmToGren.Compat.Array.append`: `a ++ b` restores Elm order.
-}
compatArrayAppend : Array a -> Array a -> Array a
compatArrayAppend lhs rhs =
    lhs ++ rhs


{-| Mirrors `ElmToGren.Compat.Array.get`: negative indices are out of range.
-}
compatArrayGet : Int -> Array a -> Maybe a
compatArrayGet index values =
    if index < 0 then
        Nothing

    else
        Array.get index values


{-| Mirrors `ElmToGren.Compat.Array.set`: negative indices leave the array
unaltered.
-}
compatArraySet : Int -> a -> Array a -> Array a
compatArraySet index value values =
    if index < 0 then
        values

    else
        Array.set index value values



-- LCG SEEDED INPUTS (Park-Miller MINSTD; pure Basics arithmetic, no modBy)


sampleCount : Int
sampleCount =
    64


lcgModulus : Int
lcgModulus =
    2147483647


{-| MINSTD step. `16807 * seed` stays below 2^53, so no precision is lost, and
modulo is taken with `//` because Basics does not expose `modBy`.
-}
lcgNext : Int -> Int
lcgNext seed =
    let
        product =
            16807 * seed
    in
    product - (product // lcgModulus) * lcgModulus


{-| `count` pseudo-random seeds derived from `initial`.
-}
seedStream : Int -> Int -> Array Int
seedStream count initial =
    let
        folded =
            Array.foldl
                (\_ acc ->
                    let
                        nextSeed =
                            lcgNext acc.seed
                    in
                    { seed = nextSeed, values = Array.pushLast nextSeed acc.values }
                )
                { seed = initial, values = [] }
                (Array.repeat count 0)
    in
    folded.values


{-| Seed reduced to 0..4 via `//` arithmetic (no modBy available).
-}
fifthRemainder : Int -> Int
fifthRemainder seed =
    seed - (seed // 5) * 5



-- ROW 1: STRING APPEND ORDER


stringAppendPreservesElmOrder : TestResult
stringAppendPreservesElmOrder =
    let
        outcomes =
            Array.map
                (\seed ->
                    let
                        lhs =
                            "L" ++ String.fromInt seed

                        rhs =
                            "R" ++ String.fromInt (lcgNext seed)

                        adapter =
                            compatStringAppend lhs rhs

                        elmOrdered =
                            String.startsWith lhs adapter
                                && String.endsWith rhs adapter
                                && String.count adapter == String.count lhs + String.count rhs

                        native =
                            String.append lhs rhs
                    in
                    { elmOrdered = elmOrdered, nativeDiverges = native /= adapter }
                )
                (seedStream sampleCount 123459871)

        divergences =
            Array.length (Array.keepIf .nativeDiverges outcomes)
    in
    { name = "String.append preserves Elm argument order (a ++ b)"
    , passed = Array.all .elmOrdered outcomes
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded pairs; adapter matches Elm order on all; Gren native String.append flips "
            ++ String.fromInt divergences
            ++ " of them"
    }



-- ROW 2: ARRAY APPEND ORDER


arrayAppendPreservesElmOrder : TestResult
arrayAppendPreservesElmOrder =
    let
        outcomes =
            Array.map
                (\seed ->
                    let
                        lhs =
                            Array.range 1 (1 + fifthRemainder seed)

                        rhs =
                            Array.range 100 (100 + fifthRemainder (lcgNext seed))

                        adapter =
                            compatArrayAppend lhs rhs

                        elmOrdered =
                            Array.takeFirst (Array.length lhs) adapter
                                == lhs
                                && Array.dropFirst (Array.length lhs) adapter
                                == rhs
                                && Array.length adapter
                                == Array.length lhs + Array.length rhs

                        native =
                            Array.append lhs rhs
                    in
                    { elmOrdered = elmOrdered, nativeDiverges = native /= adapter }
                )
                (seedStream sampleCount 987654319)

        divergences =
            Array.length (Array.keepIf .nativeDiverges outcomes)
    in
    { name = "Array.append preserves Elm argument order (a ++ b)"
    , passed = Array.all .elmOrdered outcomes
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded pairs; adapter matches Elm order on all; Gren native Array.append flips "
            ++ String.fromInt divergences
            ++ " of them"
    }



-- ROW 3: INTEGER DIVISION BY ZERO


{-| Zero the compiler cannot constant-fold: the length of an array emptied by a
runtime predicate. This keeps `n // 0` a genuine runtime division.
-}
runtimeZero : Int -> Int
runtimeZero seed =
    Array.length (Array.keepIf (\value -> value > seed && value < seed) [ seed, seed + 1, seed + 2 ])


-- ROWS 4-6: ARRAY INDEX BOUNDS (D5)


{-| Seed reduced to an index in -6..6 (covers negative, in-range, too-large).
-}
smallIndex : Int -> Int
smallIndex seed =
    (seed - (seed // 13) * 13) - 6


{-| Elm reference: out of range in EITHER direction is Nothing.
-}
elmGet : Int -> Array a -> Maybe a
elmGet index values =
    if index < 0 || index >= Array.length values then
        Nothing

    else
        Array.get index values


{-| Elm reference: out of range in EITHER direction leaves the array unaltered.
-}
elmSet : Int -> a -> Array a -> Array a
elmSet index value values =
    if index < 0 || index >= Array.length values then
        values

    else
        Array.set index value values


{-| Elm reference slice from first principles (no native slice): negative
indices count from the end, clamp to bounds, crossed range is empty.
-}
elmSlice : Int -> Int -> Array a -> Array a
elmSlice from to values =
    let
        len =
            Array.length values

        resolve raw =
            if raw < 0 then
                len + raw

            else
                raw

        lo =
            min (max 0 (resolve from)) len

        hi =
            min (max 0 (resolve to)) len
    in
    if lo >= hi then
        []

    else
        Array.dropFirst lo (Array.takeFirst hi values)


arrayGetMatchesElmBounds : TestResult
arrayGetMatchesElmBounds =
    let
        outcomes =
            Array.map
                (\seed ->
                    let
                        index =
                            smallIndex seed

                        values =
                            Array.range 1 (1 + fifthRemainder (lcgNext seed))

                        adapter =
                            compatArrayGet index values
                    in
                    { matches = adapter == elmGet index values
                    , nativeDiverges = Array.get index values /= adapter
                    }
                )
                (seedStream sampleCount 246813579)

        divergences =
            Array.length (Array.keepIf .nativeDiverges outcomes)
    in
    { name = "Array.get: out-of-range is Nothing in both directions (D5)"
    , passed = Array.all .matches outcomes && divergences > 0
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded (index, array) pairs incl. negatives; adapter == Elm on all; native Gren wraps "
            ++ String.fromInt divergences
            ++ " (non-vacuity: must be > 0)"
    }


arraySetMatchesElmBounds : TestResult
arraySetMatchesElmBounds =
    let
        outcomes =
            Array.map
                (\seed ->
                    let
                        index =
                            smallIndex seed

                        values =
                            Array.range 1 (1 + fifthRemainder (lcgNext seed))

                        adapter =
                            compatArraySet index 999 values
                    in
                    { matches = adapter == elmSet index 999 values
                    , nativeDiverges = Array.set index 999 values /= adapter
                    }
                )
                (seedStream sampleCount 135792468)

        divergences =
            Array.length (Array.keepIf .nativeDiverges outcomes)
    in
    { name = "Array.set: out-of-range leaves the array unaltered (D5)"
    , passed = Array.all .matches outcomes && divergences > 0
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded (index, array) pairs incl. negatives; adapter == Elm on all; native Gren wraps "
            ++ String.fromInt divergences
            ++ " (non-vacuity: must be > 0)"
    }


arraySliceParity : TestResult
arraySliceParity =
    let
        outcomes =
            Array.map
                (\seed ->
                    let
                        from =
                            smallIndex seed

                        to =
                            smallIndex (lcgNext seed)

                        values =
                            Array.range 1 (1 + fifthRemainder (lcgNext (lcgNext seed)))
                    in
                    Array.slice from to values == elmSlice from to values
                )
                (seedStream sampleCount 864209753)
    in
    { name = "Array.slice: Elm and Gren negative-index semantics agree (no adapter)"
    , passed = Array.all identity outcomes
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded (from, to, array) triples incl. negatives and crossed ranges"
    }


intDivideByZeroIsZero : TestResult
intDivideByZeroIsZero =
    let
        outcomes =
            Array.map
                (\seed ->
                    let
                        numerator =
                            seed - lcgModulus // 2

                        quotient =
                            numerator // runtimeZero seed
                    in
                    quotient == 0
                )
                (seedStream sampleCount 192837461)
    in
    { name = "Integer // by zero is 0 (Elm and Gren agree)"
    , passed = Array.all identity outcomes
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded numerators; n // 0 == 0 for all"
    }



-- ROW 7: MATH MODBY (floored modulo, result sign follows divisor)


{-| Elm's modBy implements floored division: the result sign follows the divisor.
Reference from first principles via truncated division (x // n * n subtraction).
-}
mathModByNonNegative : TestResult
mathModByNonNegative =
    let
        outcomes =
            Array.map
                (\seed ->
                    let
                        x =
                            seed - lcgModulus // 2

                        nAbs =
                            1 + fifthRemainder seed

                        n =
                            if fifthRemainder (lcgNext seed) == 0 then
                                negate nAbs

                            else
                                nAbs

                        truncated =
                            x - (x // n) * n

                        floored =
                            if truncated == 0 then
                                0

                            else if (truncated < 0) == (n < 0) then
                                truncated

                            else
                                truncated + n

                        actual =
                            Math.modBy n x

                        passesLaw =
                            actual == floored

                        boundsCheckForPositiveN =
                            if n > 0 then
                                actual >= 0 && actual < n

                            else
                                True
                    in
                    { passesLaw = passesLaw
                    , passesBounds = boundsCheckForPositiveN
                    }
                )
                (seedStream sampleCount 357924681)

        allPassLaw =
            Array.all .passesLaw outcomes

        allPassBounds =
            Array.all .passesBounds outcomes
    in
    { name = "Math.modBy implements floored division (result sign follows divisor)"
    , passed = allPassLaw && allPassBounds
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded (x, n) pairs, n never 0, both signs; all match floored law; positive-n results all in [0, n)"
    }



-- ROW 8: MATH REMAINDERBY (truncated remainder, result sign follows dividend)


{-| Elm's remainderBy implements truncated division: the result sign follows the dividend.
Reference is the raw truncated remainder x - (x // n) * n.
-}
mathRemainderByPreservesSign : TestResult
mathRemainderByPreservesSign =
    let
        outcomes =
            Array.map
                (\seed ->
                    let
                        x =
                            seed - lcgModulus // 2

                        nAbs =
                            1 + fifthRemainder seed

                        n =
                            if fifthRemainder (lcgNext seed) == 0 then
                                negate nAbs

                            else
                                nAbs

                        r =
                            x - (x // n) * n

                        actual =
                            Math.remainderBy n x

                        passesLaw =
                            actual == r

                        signPreserved =
                            r == 0 || (r < 0) == (x < 0)
                    in
                    { passesLaw = passesLaw
                    , signPreserved = signPreserved
                    }
                )
                (seedStream sampleCount 531469872)

        allPassLaw =
            Array.all .passesLaw outcomes

        allSignPreserved =
            Array.all .signPreserved outcomes
    in
    { name = "Math.remainderBy implements truncated division (result sign follows dividend)"
    , passed = allPassLaw && allSignPreserved
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded (x, n) pairs, n never 0, both signs; all match truncated remainder law; non-zero results preserve dividend sign"
    }



-- ROWS 9-12: CHAR CASE CONVERSION


{-| Mirrors `ElmToGren.Compat.Char.toLower`: routes through String.toLower.
-}
compatCharToLower : Char -> Char
compatCharToLower char =
    when String.popFirst (String.toLower (String.fromChar char)) is
        Just { first } ->
            first

        Nothing ->
            char


{-| Mirrors `ElmToGren.Compat.Char.toUpper`: routes through String.toUpper.
-}
compatCharToUpper : Char -> Char
compatCharToUpper char =
    when String.popFirst (String.toUpper (String.fromChar char)) is
        Just { first } ->
            first

        Nothing ->
            char


{-| Mirrors `ElmToGren.Compat.Char.toLocaleLower`: pure delegation to toLower
(Gren has no locale API; the adapter's law is locale == simple case mapping).
-}
compatCharToLocaleLower : Char -> Char
compatCharToLocaleLower char =
    compatCharToLower char


{-| Mirrors `ElmToGren.Compat.Char.toLocaleUpper`: pure delegation to toUpper.
-}
compatCharToLocaleUpper : Char -> Char
compatCharToLocaleUpper char =
    compatCharToUpper char


{-| Elm reference: toLower via Char.toCode/Char.fromCode arithmetic.
Codes 65..90 (A..Z) map to +32 (a..z); fixed non-ASCII 192->224 (À->à),
216->248 (Ø->ø); all other sampled codes unchanged.
-}
elmCharToLower : Char -> Char
elmCharToLower char =
    let
        code =
            Char.toCode char
    in
    if code >= 65 && code <= 90 then
        Char.fromCode (code + 32)

    else if code == 192 then
        Char.fromCode 224

    else if code == 216 then
        Char.fromCode 248

    else
        char


{-| Elm reference: toUpper via Char.toCode/Char.fromCode arithmetic.
Codes 97..122 (a..z) map to -32 (A..Z); 224->192, 248->216; others unchanged.
-}
elmCharToUpper : Char -> Char
elmCharToUpper char =
    let
        code =
            Char.toCode char
    in
    if code >= 97 && code <= 122 then
        Char.fromCode (code - 32)

    else if code == 224 then
        Char.fromCode 192

    else if code == 248 then
        Char.fromCode 216

    else
        char


{-| Sample pool: digits, uppercase, lowercase, ASCII symbols, plus fixed
non-ASCII pairs with known case mappings.
-}
charSamplePool : Array Char
charSamplePool =
    let
        digitCodes =
            Array.range 48 57

        upperCodes =
            Array.range 65 90

        lowerCodes =
            Array.range 97 122

        symbolCodes =
            Array.range 33 47

        allCodes =
            Array.flatten [ digitCodes, upperCodes, lowerCodes, symbolCodes, [ 192, 216, 224, 248 ] ]
    in
    Array.map Char.fromCode allCodes


{-| Pick a character from the sample pool using the seed reduced to a pool index.
-}
charFromSeed : Int -> Char
charFromSeed seed =
    let
        poolSize =
            Array.length charSamplePool

        index =
            seed - (seed // poolSize) * poolSize
    in
    when Array.get index charSamplePool is
        Just ch ->
            ch

        Nothing ->
            'a'


charToLowerMatchesElm : TestResult
charToLowerMatchesElm =
    let
        outcomes =
            Array.map
                (\seed ->
                    compatCharToLower (charFromSeed seed) == elmCharToLower (charFromSeed seed)
                )
                (seedStream sampleCount 654321987)
    in
    { name = "Char.toLower: adapter matches Elm simple-case reference (D char)"
    , passed = Array.all identity outcomes
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded chars incl. non-ASCII pairs; adapter == code-arithmetic reference on all"
    }


charToUpperMatchesElm : TestResult
charToUpperMatchesElm =
    let
        outcomes =
            Array.map
                (\seed ->
                    compatCharToUpper (charFromSeed seed) == elmCharToUpper (charFromSeed seed)
                )
                (seedStream sampleCount 789456123)
    in
    { name = "Char.toUpper: adapter matches Elm simple-case reference"
    , passed = Array.all identity outcomes
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded chars incl. non-ASCII pairs; adapter == code-arithmetic reference on all"
    }


{-| The adapter's locale law: with no locale API in Gren, toLocaleLower must
equal the Elm simple-case mapping on every char where all locales agree
(the entire sampled Latin-1 range).
-}
charToLocaleLowerMatchesElm : TestResult
charToLocaleLowerMatchesElm =
    let
        outcomes =
            Array.map
                (\seed ->
                    compatCharToLocaleLower (charFromSeed seed) == elmCharToLower (charFromSeed seed)
                )
                (seedStream sampleCount 321789654)
    in
    { name = "Char.toLocaleLower: delegating adapter matches Elm reference"
    , passed = Array.all identity outcomes
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded chars; locale adapter == Elm simple-case reference on all"
    }


charToLocaleUpperMatchesElm : TestResult
charToLocaleUpperMatchesElm =
    let
        outcomes =
            Array.map
                (\seed ->
                    compatCharToLocaleUpper (charFromSeed seed) == elmCharToUpper (charFromSeed seed)
                )
                (seedStream sampleCount 456321789)
    in
    { name = "Char.toLocaleUpper: delegating adapter matches Elm reference"
    , passed = Array.all identity outcomes
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded chars; locale adapter == Elm simple-case reference on all"
    }



-- ROWS 13-14: STRING CONCAT AND UNCONS


{-| Mirrors `ElmToGren.Compat.String.concat`: String.join "".
-}
compatStringConcat : Array String -> String
compatStringConcat strings =
    String.join "" strings


{-| Elm reference from first principles: left fold with Elm-order (++).
-}
elmStringConcat : Array String -> String
elmStringConcat strings =
    Array.foldl (\part acc -> acc ++ part) "" strings


stringConcatMatchesElm : TestResult
stringConcatMatchesElm =
    let
        outcomes =
            Array.map
                (\seed ->
                    let
                        strings =
                            Array.range 0 (fifthRemainder seed - 1)
                                |> Array.map (\i -> "S" ++ String.fromInt (fifthRemainder (seed + i)))

                        joined =
                            compatStringConcat strings

                        orderKept =
                            when Array.get 0 strings is
                                Just firstPart ->
                                    String.startsWith firstPart joined

                                Nothing ->
                                    joined == ""
                    in
                    joined == elmStringConcat strings && orderKept
                )
                (seedStream sampleCount 246897531)
    in
    { name = "String.concat: adapter matches Elm fold reference (order preserved)"
    , passed = Array.all identity outcomes
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded arrays of 0..4 strings incl. empty; adapter == foldl (++) reference on all"
    }


{-| Mirrors `ElmToGren.Compat.String.uncons`: popFirst reshaped to {first, second}.
-}
compatStringUncons : String -> Maybe { first : Char, second : String }
compatStringUncons string =
    when String.popFirst string is
        Just { first, rest } ->
            Just { first = first, second = rest }

        Nothing ->
            Nothing


{-| Elm reference from first principles: char array get/drop, no popFirst.
-}
elmStringUncons : String -> Maybe { first : Char, second : String }
elmStringUncons string =
    let
        chars =
            String.toArray string
    in
    when Array.get 0 chars is
        Just firstChar ->
            Just { first = firstChar, second = String.fromArray (Array.dropFirst 1 chars) }

        Nothing ->
            Nothing


stringUnconsMatchesElm : TestResult
stringUnconsMatchesElm =
    let
        samples =
            [ "" ]
                ++ Array.map
                    (\seed ->
                        Array.range 0 (fifthRemainder seed - 1)
                            |> Array.map (\i -> String.fromChar (Char.fromCode (65 + fifthRemainder (seed + i))))
                            |> String.join ""
                    )
                    (seedStream sampleCount 135798642)

        outcomes =
            Array.map
                (\sample -> compatStringUncons sample == elmStringUncons sample)
                samples
    in
    { name = "String.uncons: adapter matches Elm reference incl. empty string"
    , passed = Array.all identity outcomes
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded strings of length 0..4 plus explicit \"\"; adapter == get/drop reference on all"
    }



-- ROW 15: ARRAY INITIALIZE


{-| Mirrors `ElmToGren.Compat.Array.initialize`: count <= 0 guarded to empty,
because Gren's `Array.initialize` throws a RangeError on negative counts where
Elm returns []. The guard IS the divergence this row documents.
-}
compatArrayInitialize : Int -> (Int -> a) -> Array a
compatArrayInitialize count make =
    if count <= 0 then
        []

    else
        Array.initialize count 0 make


{-| Elm reference: n <= 0 is empty; else make applied over 0..n-1.
-}
elmArrayInitialize : Int -> (Int -> a) -> Array a
elmArrayInitialize n make =
    if n <= 0 then
        []

    else
        Array.map make (Array.range 0 (n - 1))


arrayInitializeMatchesElm : TestResult
arrayInitializeMatchesElm =
    let
        outcomes =
            Array.map
                (\seed ->
                    let
                        n =
                            smallIndex seed

                        offset =
                            fifthRemainder seed

                        make =
                            \i -> i * 7 + offset
                    in
                    compatArrayInitialize n make == elmArrayInitialize n make
                )
                (seedStream sampleCount 975318642)
    in
    { name = "Array.initialize: adapter matches Elm reference incl. n <= 0"
    , passed = Array.all identity outcomes
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded n in -6..6; adapter == range/map reference on all"
    }



-- ROWS 16-17: LIST TAIL AND PARTITION


{-| Mirrors `ElmToGren.Compat.List.tail`: popFirst rest.
-}
compatListTail : Array Int -> Maybe (Array Int)
compatListTail values =
    when Array.popFirst values is
        Just { rest } ->
            Just rest

        Nothing ->
            Nothing


{-| Elm reference: tail [] == Nothing; tail (x::xs) == Just xs, via dropFirst.
-}
elmListTail : Array Int -> Maybe (Array Int)
elmListTail values =
    if Array.length values == 0 then
        Nothing

    else
        Just (Array.dropFirst 1 values)


{-| Seeded sample: length 0..4 from the 0..4 value domain, with an explicit
duplicate of the first element appended to every non-empty sample so order
preservation over duplicates is always exercised.
-}
listSampleFromSeed : Int -> Array Int
listSampleFromSeed seed =
    let
        base =
            Array.range 0 (fifthRemainder seed - 1)
                |> Array.map (\i -> fifthRemainder (seed + i))
    in
    base ++ Array.takeFirst 1 base


listTailMatchesElm : TestResult
listTailMatchesElm =
    let
        outcomes =
            Array.map
                (\seed ->
                    let
                        sample =
                            listSampleFromSeed seed
                    in
                    compatListTail sample == elmListTail sample
                )
                (seedStream sampleCount 864197532)
    in
    { name = "List.tail: adapter matches Elm reference incl. empty"
    , passed = Array.all identity outcomes
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded arrays of length 0..5 with duplicates; adapter == dropFirst reference on all"
    }


{-| Mirrors `ElmToGren.Compat.List.partition`: Gren partition reshaped to {first, second}.
-}
compatListPartition : (Int -> Bool) -> Array Int -> { first : Array Int, second : Array Int }
compatListPartition predicate values =
    let
        parts =
            Array.partition predicate values
    in
    { first = parts.trues, second = parts.falses }


{-| Elm reference: order-preserving double keepIf.
-}
elmListPartition : (Int -> Bool) -> Array Int -> { first : Array Int, second : Array Int }
elmListPartition predicate values =
    { first = Array.keepIf predicate values
    , second = Array.keepIf (\value -> not (predicate value)) values
    }


listPartitionMatchesElm : TestResult
listPartitionMatchesElm =
    let
        outcomes =
            Array.map
                (\seed ->
                    let
                        sample =
                            listSampleFromSeed seed

                        threshold =
                            fifthRemainder (lcgNext seed)

                        predicate =
                            \value -> value > threshold
                    in
                    compatListPartition predicate sample == elmListPartition predicate sample
                )
                (seedStream sampleCount 753186429)
    in
    { name = "List.partition: adapter matches Elm order-preserving reference"
    , passed = Array.all identity outcomes
    , details =
        String.fromInt (Array.length outcomes)
            ++ " seeded arrays with duplicates, seeded thresholds; adapter == double-keepIf reference on all"
    }



-- ROWS 18-21: DICT AND SET


{-| Mirrors `ElmToGren.Compat.Dict.toList`: foldr + pushFirst gives ascending order.
-}
dictsetCompatDictToList : Dict Int Int -> Array { first : Int, second : Int }
dictsetCompatDictToList dictionary =
    Dict.foldr
        (\key value pairs -> Array.pushFirst { first = key, second = value } pairs)
        []
        dictionary


{-| Mirrors `ElmToGren.Compat.Dict.fromList`: foldl Dict.set, last wins.
-}
dictsetCompatDictFromList : Array { first : Int, second : Int } -> Dict Int Int
dictsetCompatDictFromList pairs =
    Array.foldl
        (\pair dictionary -> Dict.set pair.first pair.second dictionary)
        Dict.empty
        pairs


{-| Mirrors `ElmToGren.Compat.Dict.partition`: Gren partition reshaped to {first, second}.
-}
dictsetCompatDictPartition : (Int -> Int -> Bool) -> Dict Int Int -> { first : Dict Int Int, second : Dict Int Int }
dictsetCompatDictPartition predicate dictionary =
    let
        parts =
            Dict.partition predicate dictionary
    in
    { first = parts.trues, second = parts.falses }


{-| Mirrors `ElmToGren.Compat.Set.partition`: Gren partition reshaped to {first, second}.
-}
dictsetCompatSetPartition : (Int -> Bool) -> Set Int -> { first : Set Int, second : Set Int }
dictsetCompatSetPartition predicate values =
    let
        parts =
            Set.partition predicate values
    in
    { first = parts.trues, second = parts.falses }


{-| Distinct keys of a pair array, first-seen order, no Dict machinery.
-}
dictsetDistinctKeys : Array { first : Int, second : Int } -> Array Int
dictsetDistinctKeys pairs =
    Array.foldl
        (\pair acc ->
            if Array.any (\known -> known == pair.first) acc then
                acc

            else
                Array.pushLast pair.first acc
        )
        []
        pairs


{-| Last value bound to a key in a pair array, by left-to-right scan.
-}
dictsetLastValueFor : Int -> Array { first : Int, second : Int } -> Maybe Int
dictsetLastValueFor key pairs =
    Array.foldl
        (\pair acc ->
            if pair.first == key then
                Just pair.second

            else
                acc
        )
        Nothing
        pairs


{-| Elm Dict.toList reference from first principles: last value per distinct
key from the raw pairs, keys sorted ascending — no Dict iteration involved.
-}
dictsetElmDictToListReference : Array { first : Int, second : Int } -> Array { first : Int, second : Int }
dictsetElmDictToListReference pairs =
    dictsetDistinctKeys pairs
        |> Array.sort
        |> Array.map
            (\key ->
                { first = key
                , second = Maybe.withDefault 0 (dictsetLastValueFor key pairs)
                }
            )


{-| Elm Dict.partition reference: fold raw last-wins entries into two Dicts by predicate.
-}
dictsetElmDictPartitionReference :
    (Int -> Int -> Bool)
    -> Array { first : Int, second : Int }
    -> { first : Dict Int Int, second : Dict Int Int }
dictsetElmDictPartitionReference predicate pairs =
    dictsetDistinctKeys pairs
        |> Array.foldl
            (\key acc ->
                let
                    value =
                        Maybe.withDefault 0 (dictsetLastValueFor key pairs)
                in
                if predicate key value then
                    { first = Dict.set key value acc.first, second = acc.second }

                else
                    { first = acc.first, second = Dict.set key value acc.second }
            )
            { first = Dict.empty, second = Dict.empty }


{-| Elm Set.partition reference: fold distinct member values into two Sets by predicate.
-}
dictsetElmSetPartitionReference :
    (Int -> Bool)
    -> Array Int
    -> { first : Set Int, second : Set Int }
dictsetElmSetPartitionReference predicate values =
    Array.foldl
        (\value acc ->
            if predicate value then
                { first = Set.set value acc.first, second = acc.second }

            else
                { first = acc.first, second = Set.set value acc.second }
        )
        { first = Set.empty, second = Set.empty }
        values


{-| Seeded pairs: keys 0..4 (guaranteed duplicates over 32 pairs), seed values.
-}
dictsetPairsFromSeeds : Array Int -> Array { first : Int, second : Int }
dictsetPairsFromSeeds seeds =
    Array.indexedMap
        (\idx seed -> { first = fifthRemainder idx, second = seed })
        seeds


{-| Canonical dict form for comparison: foldr into a pair array.
-}
dictsetCanonical : Dict Int Int -> Array { first : Int, second : Int }
dictsetCanonical dictionary =
    Dict.foldr
        (\key value acc -> Array.pushFirst { first = key, second = value } acc)
        []
        dictionary


dictsetDictsEqual : Dict Int Int -> Dict Int Int -> Bool
dictsetDictsEqual d1 d2 =
    dictsetCanonical d1 == dictsetCanonical d2


dictsetDictsDisjoint : Dict Int Int -> Dict Int Int -> Bool
dictsetDictsDisjoint d1 d2 =
    Dict.foldl
        (\key _ acc ->
            when Dict.get key d2 is
                Just _ ->
                    False

                Nothing ->
                    acc
        )
        True
        d1


dictsetDictUnion : Dict Int Int -> Dict Int Int -> Dict Int Int
dictsetDictUnion d1 d2 =
    Dict.foldl (\key value acc -> Dict.set key value acc) d1 d2


dictsetSetsEqual : Set Int -> Set Int -> Bool
dictsetSetsEqual s1 s2 =
    Set.foldr Array.pushLast [] s1 == Set.foldr Array.pushLast [] s2


dictsetSetsDisjoint : Set Int -> Set Int -> Bool
dictsetSetsDisjoint s1 s2 =
    Set.foldl
        (\value acc ->
            if Set.member value s2 then
                False

            else
                acc
        )
        True
        s1


dictsetSetUnion : Set Int -> Set Int -> Set Int
dictsetSetUnion s1 s2 =
    Set.foldl Set.set s1 s2


dictToListMatchesElm : TestResult
dictToListMatchesElm =
    let
        pairs =
            dictsetPairsFromSeeds (seedStream 32 424242001)

        result =
            dictsetCompatDictToList (dictsetCompatDictFromList pairs)

        expected =
            dictsetElmDictToListReference pairs
    in
    { name = "Dict.toList: adapter returns ascending pairs matching raw-scan reference"
    , passed = result == expected
    , details =
        "32 seeded pairs over 5 keys (duplicates guaranteed); adapter == sorted last-wins pair scan"
    }


dictFromListMatchesElm : TestResult
dictFromListMatchesElm =
    let
        pairs =
            dictsetPairsFromSeeds (seedStream 32 424242001)

        dict =
            dictsetCompatDictFromList pairs

        distinctKeys =
            dictsetDistinctKeys pairs

        lastWinsHolds =
            Array.all
                (\key -> Dict.get key dict == dictsetLastValueFor key pairs)
                distinctKeys

        sizeMatches =
            Dict.count dict == Array.length distinctKeys

        duplicatesExercised =
            Array.length pairs > Array.length distinctKeys
    in
    { name = "Dict.fromList: last duplicate wins per key (law-based check)"
    , passed = lastWinsHolds && sizeMatches && duplicatesExercised
    , details =
        "32 seeded pairs over 5 keys; Dict.get per key == last scanned value; size == distinct keys; non-vacuity: duplicates present"
    }


dictPartitionMatchesElm : TestResult
dictPartitionMatchesElm =
    let
        seeds =
            seedStream 32 424242001

        pairs =
            dictsetPairsFromSeeds seeds

        dict =
            dictsetCompatDictFromList pairs

        threshold =
            lcgModulus // 2

        predicate =
            \_ value -> value < threshold

        result =
            dictsetCompatDictPartition predicate dict

        expected =
            dictsetElmDictPartitionReference predicate pairs

        matchesReference =
            dictsetDictsEqual result.first expected.first
                && dictsetDictsEqual result.second expected.second

        disjoint =
            dictsetDictsDisjoint result.first result.second

        unionRestores =
            dictsetDictsEqual (dictsetDictUnion result.first result.second) dict
    in
    { name = "Dict.partition: adapter matches fold reference; disjoint; union restores"
    , passed = matchesReference && disjoint && unionRestores
    , details =
        "32 seeded pairs, midpoint value threshold; both sides match reference, disjoint, union == original"
    }


setPartitionMatchesElm : TestResult
setPartitionMatchesElm =
    let
        members =
            seedStream 32 424242007
                |> Array.map fifthRemainder

        set =
            Array.foldl Set.set Set.empty members

        limit =
            2

        predicate =
            \value -> value < limit

        result =
            dictsetCompatSetPartition predicate set

        expected =
            dictsetElmSetPartitionReference predicate members

        matchesReference =
            dictsetSetsEqual result.first expected.first
                && dictsetSetsEqual result.second expected.second

        disjoint =
            dictsetSetsDisjoint result.first result.second

        unionRestores =
            dictsetSetsEqual (dictsetSetUnion result.first result.second) set
    in
    { name = "Set.partition: adapter matches fold reference; disjoint; union restores"
    , passed = matchesReference && disjoint && unionRestores
    , details =
        "32 seeded members in 0..4, split at 2; both sides match reference, disjoint, union == original"
    }
