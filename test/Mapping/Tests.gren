module Mapping.Tests exposing (Check, allPassed, checks, failures)

import Array
import Dict
import Mapping.Adapter as Adapter
import Mapping.Decode as MappingDecode
import Mapping.Registry as Registry
import Mapping.Types exposing (AdapterId(..), PackageMapping(..), Platform(..))
import Maybe exposing (Maybe(..))
import Result exposing (Result(..))


type alias Check =
    { name : String
    , passed : Bool
    }


checks : Array Check
checks =
    [ check "valid mapping JSON decodes into typed variants" validDocumentDecodes
    , check "invalid optional maps are rejected instead of defaulted" invalidOptionalMapRejected
    , check "duplicate module declarations are rejected" duplicateModuleRejected
    , check "overlay replacement moves package to the final position" overlayOrderIsStable
    , check "transpile overlay removes stale module mappings" transpileRemovesModules
    , check "module collisions resolve according to package overlay order" moduleCollisionUsesLastPackage
    , check "platform inference selects the narrowest host" platformInferenceWorks
    , check "browser and node evidence produces a typed conflict" platformConflictIsTyped
    , check "adapter discovery follows fully-qualified target symbols" adapterDiscoveryWorks
    , check "adapter generation is sorted and de-duplicated" adapterGenerationIsDeterministic
    , check "Tuple adapter contains record-pair semantics" tupleAdapterIsSemantic
    , check "JSON encoding adapter converts pair field names" jsonEncodeAdapterIsSemantic
    , check "List and Array adapters preserve collection conversions" listAndArrayAdaptersAreSemantic
    , check "Char adapter is registered and discoverable from catalog targets" charAdapterCatalogWiring
    , check "Char adapter routes case conversion through String" charAdapterIsSemantic
    , check "Browser adapter rewrites TEA pairs for element/document/application" browserAdapterIsSemantic
    , check "Html classList and event adapters convert pair records" htmlAdaptersAreSemantic
    , check "Bytes.Encode and Random.step adapters bridge Gren record shapes" bytesAndRandomAdaptersAreSemantic
    , check "browser catalog targets discover nested Compat adapters" browserAdaptersCatalogWiring
    , check "mapping lexical validation matches the JSON contract" lexicalValidationWorks
    ]


allPassed : Bool
allPassed =
    Array.all .passed checks


failures : Array String
failures =
    checks
        |> Array.keepIf (\item -> not item.passed)
        |> Array.map .name


check : String -> Bool -> Check
check name passed =
    { name = name, passed = passed }


isErr result =
    when result is
        Err _ ->
            True

        Ok _ ->
            False


validDocumentDecodes : Bool
validDocumentDecodes =
    when MappingDecode.decodeString "valid.json" baseDocumentJson is
        Ok document ->
            document.schemaVersion == 1
                && Array.length document.packages == 2
                && when Array.get 0 document.packages is
                    Just (GrenAnalogue details) ->
                        details.elmPackage == "elm/core"
                            && details.grenPackage == "gren-lang/core"
                            && details.platform == Common

                    _ ->
                        False

        Err _ ->
            False


invalidOptionalMapRejected : Bool
invalidOptionalMapRejected =
    MappingDecode.decodeString "invalid-map.json"
        """
{
  "schemaVersion": 1,
  "packages": [{
    "kind": "gren-analogue",
    "elmPackage": "elm/core",
    "grenPackage": "gren-lang/core",
    "grenVersion": "7.4.2",
    "platform": "common",
    "modules": [{ "source": "Basics", "target": "Basics", "values": [], "types": {} }]
  }]
}
"""
        |> isErr


duplicateModuleRejected : Bool
duplicateModuleRejected =
    MappingDecode.decodeString "duplicate.json"
        """
{
  "schemaVersion": 1,
  "packages": [{
    "kind": "absorbed",
    "elmPackage": "elm/json",
    "grenPackage": "gren-lang/core",
    "grenVersion": "7.4.2",
    "platform": "common",
    "modules": [
      { "source": "Json.Decode", "target": "Json.Decode", "values": {}, "types": {} },
      { "source": "Json.Decode", "target": "Json.Decode", "values": {}, "types": {} }
    ]
  }]
}
"""
        |> isErr


overlayOrderIsStable : Bool
overlayOrderIsStable =
    when decodedDocuments is
        Just documents ->
            let
                registry =
                    Registry.overlayDocuments documents
            in
            registry.packageOrder == [ "elm/html", "elm/core" ]

        Nothing ->
            False


transpileRemovesModules : Bool
transpileRemovesModules =
    when decodedDocuments is
        Just documents ->
            let
                registry =
                    Registry.overlayDocuments documents
            in
            Registry.moduleMappingFor "Basics" registry == Nothing
                && when Registry.mappingFor "elm/core" registry is
                    Just (Transpile details) ->
                        details.grenPackage == "ported/elm--core"

                    _ ->
                        False

        Nothing ->
            False


moduleCollisionUsesLastPackage : Bool
moduleCollisionUsesLastPackage =
    when MappingDecode.decodeString "collision.json" collisionDocumentJson is
        Ok document ->
            when Registry.moduleMappingFor "Shared" (Registry.fromDocument document) is
                Just module_ ->
                    module_.target == "Second.Shared"

                Nothing ->
                    False

        Err _ ->
            False


platformInferenceWorks : Bool
platformInferenceWorks =
    when MappingDecode.decodeString "base.json" baseDocumentJson is
        Ok document ->
            let
                registry =
                    Registry.fromDocument document
            in
            Registry.inferPlatform registry [ "elm/core" ] [] == Ok Common
                && Registry.inferPlatform registry [ "elm/html" ] [] == Ok Browser
                && Registry.inferPlatform registry [] [ Node ] == Ok Node

        Err _ ->
            False


platformConflictIsTyped : Bool
platformConflictIsTyped =
    when MappingDecode.decodeString "base.json" baseDocumentJson is
        Ok document ->
            when Registry.inferPlatform (Registry.fromDocument document) [ "elm/html" ] [ Node ] is
                Err _ ->
                    True

                Ok _ ->
                    False

        Err _ ->
            False


adapterDiscoveryWorks : Bool
adapterDiscoveryWorks =
    Adapter.adapterModuleForTarget "ElmToGren.Compat.Json.Decode.keyValuePairs"
        == Just "ElmToGren.Compat.Json.Decode"
        && Adapter.adapterModuleForTarget "Array.keepIf" == Nothing
        && Adapter.requiredForModules
            [ { source = "List"
              , target = "Array"
              , values =
                    Dict.empty
                        |> Dict.set "tail" "ElmToGren.Compat.List.tail"
                        |> Dict.set "fromList" "ElmToGren.Compat.Array.fromList"
              , types = Dict.empty
              }
            ]
            == [ ArrayAdapter, ListAdapter ]


adapterGenerationIsDeterministic : Bool
adapterGenerationIsDeterministic =
    when Adapter.generateFromRequirements
        [ "list"
        , "ElmToGren.Compat.Array.initialize"
        , "List"
        , "Tuple"
        ]
    is
        Ok modules ->
            Array.map .moduleName modules
                == [ "ElmToGren.Compat.Array"
                   , "ElmToGren.Compat.List"
                   , "ElmToGren.Compat.Tuple"
                   ]
                && when Array.get 0 modules is
                    Just firstModule ->
                        firstModule.relativePath == "ElmToGren/Compat/Array.gren"

                    Nothing ->
                        False

        Err _ ->
            False


tupleAdapterIsSemantic : Bool
tupleAdapterIsSemantic =
    Adapter.sourceFor TupleAdapter
        |> String.contains "{ first = firstValue, second = secondValue }"


jsonEncodeAdapterIsSemantic : Bool
jsonEncodeAdapterIsSemantic =
    Adapter.sourceFor JsonEncodeAdapter
        |> String.contains "{ key = pair.first, value = pair.second }"


listAndArrayAdaptersAreSemantic : Bool
listAndArrayAdaptersAreSemantic =
    String.contains "Array.foldl (+) 0 values" (Adapter.sourceFor ListAdapter)
        && String.contains "fromList values =" (Adapter.sourceFor ArrayAdapter)
        && String.contains "toList values =" (Adapter.sourceFor ArrayAdapter)


{-| Catalog-shaped Char mapping must discover the Compat adapter, normalize
from FQ symbols, and generate a single module with the expected path.
Kernel `Char` alone must not pull the adapter in (values are FQ, target is not).
-}
charAdapterCatalogWiring : Bool
charAdapterCatalogWiring =
    let
        charCatalogMapping =
            { source = "Char"
            , target = "Char"
            , values =
                Dict.empty
                    |> Dict.set "toLower" "ElmToGren.Compat.Char.toLower"
                    |> Dict.set "toUpper" "ElmToGren.Compat.Char.toUpper"
                    |> Dict.set "toLocaleLower" "ElmToGren.Compat.Char.toLocaleLower"
                    |> Dict.set "toLocaleUpper" "ElmToGren.Compat.Char.toLocaleUpper"
            , types = Dict.singleton "Char" "Char"
            }

        bareCharMapping =
            { source = "Char"
            , target = "Char"
            , values = Dict.empty
            , types = Dict.singleton "Char" "Char"
            }

        registered =
            Array.any (\adapterId -> adapterId == CharAdapter) Adapter.all
    in
    registered
        && Adapter.moduleName CharAdapter
            == "ElmToGren.Compat.Char"
        && Adapter.adapterModuleForTarget "ElmToGren.Compat.Char.toLower"
            == Just "ElmToGren.Compat.Char"
        && Adapter.adapterModuleForTarget "ElmToGren.Compat.Char.toLocaleUpper"
            == Just "ElmToGren.Compat.Char"
        && Adapter.adapterIdForTarget "ElmToGren.Compat.Char.toUpper"
            == Just CharAdapter
        && Adapter.adapterIdForTarget "Char"
            == Nothing
        && Adapter.requiredForModules [ charCatalogMapping ]
            == [ CharAdapter ]
        && Adapter.requiredForModules [ bareCharMapping ]
            == []
        && Adapter.normalize "Char"
            == Ok CharAdapter
        && Adapter.normalize "ElmToGren.Compat.Char.toLocaleLower"
            == Ok CharAdapter
        && when Adapter.generateFromRequirements
            [ "ElmToGren.Compat.Char.toLower"
            , "char"
            , "ElmToGren.Compat.Char.toUpper"
            ]
        is
            Ok modules ->
                Array.map .moduleName modules
                    == [ "ElmToGren.Compat.Char" ]
                    && when Array.get 0 modules is
                        Just generated ->
                            generated.relativePath
                                == "ElmToGren/Compat/Char.gren"
                                && String.contains
                                    "module ElmToGren.Compat.Char exposing (toLower, toUpper, toLocaleLower, toLocaleUpper)"
                                    generated.source

                        Nothing ->
                            False

            Err _ ->
                False


{-| Generated Compat.Char must case via String kernel helpers and map locale
variants onto the non-locale implementations (Gren has no locale Char API).
-}
charAdapterIsSemantic : Bool
charAdapterIsSemantic =
    let
        source =
            Adapter.sourceFor CharAdapter
    in
    String.contains "String.toLower (String.fromChar char)" source
        && String.contains "String.toUpper (String.fromChar char)" source
        && String.contains "String.popFirst" source
        && String.contains "Just { first } ->" source
        && String.contains "Nothing ->" source
        && String.contains "toLocaleLower char =\n    toLower char" source
        && String.contains "toLocaleUpper char =\n    toUpper char" source


{-| Browser element/document/application must map Elm TEA pairs
`{ first, second }` onto Gren `{ model, command }`.
-}
browserAdapterIsSemantic : Bool
browserAdapterIsSemantic =
    let
        source =
            Adapter.sourceFor BrowserAdapter
    in
    String.contains "exposing (element, document, application)" source
        && String.contains "{ model = pair.first, command = pair.second }" source
        && String.contains "Browser.element" source
        && String.contains "Browser.document" source
        && String.contains "Browser.application" source
        && String.contains "\\flags url key -> teaPair (config.init flags url key)" source
        && String.contains "onUrlRequest = config.onUrlRequest" source
        && String.contains "onUrlChange = config.onUrlChange" source


{-| classList maps pair records to `{ class, enabled }`; event helpers map
pair decoders to Gren's named preventDefault/stopPropagation fields.
VirtualDom.Handler May* variants get the same treatment as Html.Events.
-}
htmlAdaptersAreSemantic : Bool
htmlAdaptersAreSemantic =
    let
        attributes =
            Adapter.sourceFor HtmlAttributesAdapter

        events =
            Adapter.sourceFor HtmlEventsAdapter

        handlers =
            Adapter.sourceFor VirtualDomHandlerAdapter
    in
    String.contains "{ class = pair.first" attributes
        && String.contains ", enabled = pair.second" attributes
        && String.contains "Html.Attributes.classList" attributes
        && String.contains "preventDefault = pair.second" events
        && String.contains "stopPropagation = pair.second" events
        && String.contains "message = pair.first" events
        && String.contains "Html.Events.preventDefaultOn" events
        && String.contains "Html.Events.stopPropagationOn" events
        && String.contains "exposing (mayPreventDefault, mayStopPropagation)" handlers
        && String.contains "VirtualDom.MayPreventDefault" handlers
        && String.contains "VirtualDom.MayStopPropagation" handlers
        && String.contains "preventDefault = pair.second" handlers
        && String.contains "stopPropagation = pair.second" handlers


{-| Bytes.Encode.string routes through Bytes.fromString; Random.step rewrites
Gren `{ value, seed }` into ported pair records.
-}
bytesAndRandomAdaptersAreSemantic : Bool
bytesAndRandomAdaptersAreSemantic =
    let
        bytes =
            Adapter.sourceFor BytesEncodeAdapter

        random =
            Adapter.sourceFor RandomAdapter
    in
    String.contains "Bytes.Encode.bytes (Bytes.fromString value)" bytes
        && String.contains "Bytes.length (Bytes.fromString value)" bytes
        && String.contains "first = result.value" random
        && String.contains "second = result.seed" random
        && String.contains "Random.step generator seed" random


{-| Catalog-shaped browser/html/bytes targets must discover nested Compat
modules (including multi-segment names) and emit the expected paths.
-}
browserAdaptersCatalogWiring : Bool
browserAdaptersCatalogWiring =
    let
        browserMapping =
            { source = "Browser"
            , target = "Browser"
            , values =
                Dict.empty
                    |> Dict.set "element" "ElmToGren.Compat.Browser.element"
                    |> Dict.set "document" "ElmToGren.Compat.Browser.document"
                    |> Dict.set "application" "ElmToGren.Compat.Browser.application"
            , types = Dict.empty
            }

        htmlEventsMapping =
            { source = "Html.Events"
            , target = "Html.Events"
            , values =
                Dict.empty
                    |> Dict.set "preventDefaultOn" "ElmToGren.Compat.Html.Events.preventDefaultOn"
                    |> Dict.set "stopPropagationOn" "ElmToGren.Compat.Html.Events.stopPropagationOn"
            , types = Dict.empty
            }

        svgEventsMapping =
            { source = "Svg.Events"
            , target = "Svg.Events"
            , values =
                Dict.empty
                    |> Dict.set "preventDefaultOn" "ElmToGren.Compat.Html.Events.preventDefaultOn"
            , types = Dict.empty
            }

        bytesMapping =
            { source = "Bytes.Encode"
            , target = "Bytes.Encode"
            , values =
                Dict.empty
                    |> Dict.set "string" "ElmToGren.Compat.Bytes.Encode.string"
                    |> Dict.set "getStringWidth" "ElmToGren.Compat.Bytes.Encode.getStringWidth"
            , types = Dict.empty
            }

        attributesMapping =
            { source = "Html.Attributes"
            , target = "Html.Attributes"
            , values = Dict.singleton "classList" "ElmToGren.Compat.Html.Attributes.classList"
            , types = Dict.empty
            }
    in
    Adapter.moduleName BrowserAdapter
        == "ElmToGren.Compat.Browser"
        && Adapter.moduleName BytesEncodeAdapter
            == "ElmToGren.Compat.Bytes.Encode"
        && Adapter.moduleName HtmlAttributesAdapter
            == "ElmToGren.Compat.Html.Attributes"
        && Adapter.moduleName HtmlEventsAdapter
            == "ElmToGren.Compat.Html.Events"
        && Adapter.adapterIdForTarget "ElmToGren.Compat.Browser.application"
            == Just BrowserAdapter
        && Adapter.adapterIdForTarget "ElmToGren.Compat.Bytes.Encode.string"
            == Just BytesEncodeAdapter
        && Adapter.adapterIdForTarget "ElmToGren.Compat.Html.Attributes.classList"
            == Just HtmlAttributesAdapter
        && Adapter.adapterIdForTarget "ElmToGren.Compat.Html.Events.preventDefaultOn"
            == Just HtmlEventsAdapter
        && Adapter.requiredForModules [ browserMapping ]
            == [ BrowserAdapter ]
        && Adapter.requiredForModules [ htmlEventsMapping ]
            == [ HtmlEventsAdapter ]
        && Adapter.requiredForModules [ svgEventsMapping ]
            == [ HtmlEventsAdapter ]
        && Adapter.requiredForModules [ bytesMapping ]
            == [ BytesEncodeAdapter ]
        && Adapter.requiredForModules [ attributesMapping ]
            == [ HtmlAttributesAdapter ]
        && when Adapter.generateFromRequirements
            [ "ElmToGren.Compat.Browser.element"
            , "ElmToGren.Compat.Bytes.Encode.string"
            , "ElmToGren.Compat.Html.Attributes.classList"
            , "ElmToGren.Compat.Html.Events.custom"
            ]
        is
            Ok modules ->
                Array.map .moduleName modules
                    == [ "ElmToGren.Compat.Browser"
                       , "ElmToGren.Compat.Bytes.Encode"
                       , "ElmToGren.Compat.Html.Attributes"
                       , "ElmToGren.Compat.Html.Events"
                       ]
                    && Array.map .relativePath modules
                        == [ "ElmToGren/Compat/Browser.gren"
                           , "ElmToGren/Compat/Bytes/Encode.gren"
                           , "ElmToGren/Compat/Html/Attributes.gren"
                           , "ElmToGren/Compat/Html/Events.gren"
                           ]

            Err _ ->
                False


lexicalValidationWorks : Bool
lexicalValidationWorks =
    MappingDecode.isValidElmPackageName "NoRedInk/elm-json-decode-pipeline"
        && not (MappingDecode.isValidGrenPackageName "NoRedInk/port")
        && MappingDecode.isValidGrenPackageName "noredink/port"
        && MappingDecode.isValidModuleName "Json.Decode"
        && MappingDecode.isValidSourceSymbol "(::)"
        && MappingDecode.isValidTargetSymbol "Math.round"
        && not (MappingDecode.isValidTargetSymbol "Math round")
        && MappingDecode.isValidSemanticVersion "7.4.2"
        && not (MappingDecode.isValidSemanticVersion "07.4.2")


decodedDocuments =
    when MappingDecode.decodeString "base.json" baseDocumentJson is
        Ok base ->
            when MappingDecode.decodeString "overlay.json" transpileOverlayJson is
                Ok overlay ->
                    Just [ base, overlay ]

                Err _ ->
                    Nothing

        Err _ ->
            Nothing


baseDocumentJson : String
baseDocumentJson =
    """
{
  "schemaVersion": 1,
  "packages": [
    {
      "kind": "gren-analogue",
      "elmPackage": "elm/core",
      "grenPackage": "gren-lang/core",
      "grenVersion": "7.4.2",
      "platform": "common",
      "modules": [{
        "source": "Basics",
        "target": "Basics",
        "values": { "round": "Math.round" },
        "types": {}
      }]
    },
    {
      "kind": "absorbed",
      "elmPackage": "elm/html",
      "grenPackage": "gren-lang/browser",
      "grenVersion": "6.0.2",
      "platform": "browser",
      "modules": [{ "source": "Html", "target": "Html", "values": {}, "types": {} }]
    }
  ]
}
"""


transpileOverlayJson : String
transpileOverlayJson =
    """
{
  "schemaVersion": 1,
  "packages": [{
    "kind": "transpile",
    "elmPackage": "elm/core",
    "grenPackage": "ported/elm--core"
  }]
}
"""


collisionDocumentJson : String
collisionDocumentJson =
    """
{
  "schemaVersion": 1,
  "packages": [
    {
      "kind": "gren-analogue",
      "elmPackage": "one/shared",
      "grenPackage": "one/shared",
      "grenVersion": "1.0.0",
      "platform": "common",
      "modules": [{ "source": "Shared", "target": "First.Shared" }]
    },
    {
      "kind": "gren-analogue",
      "elmPackage": "two/shared",
      "grenPackage": "two/shared",
      "grenVersion": "1.0.0",
      "platform": "common",
      "modules": [{ "source": "Shared", "target": "Second.Shared" }]
    }
  ]
}
"""
