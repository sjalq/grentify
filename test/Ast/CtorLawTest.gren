module Ast.CtorLawTest exposing (tests)

{-| CtorLaw unit checks: multi-arg helpers and short-name isolation.
-}

import Array exposing (Array)
import Ast.BareResolve as BareResolve
import Ast.CtorLaw as CtorLaw
import Ast.NameSub as NameSub
import Ast.Print as Print
import Ast.RecordAlias as RecordAlias
import Ast.Types exposing
    ( Declaration(..)
    , Exposing(..)
    , Expr(..)
    , File
    , ModuleKind(..)
    , Pattern(..)
    , TypeAnn(..)
    )
import Dict exposing (Dict)
import Mapping.Types exposing (Registry)
import String


type alias TestResult =
    { name : String
    , passed : Bool
    , details : String
    }


tests : Array TestResult
tests =
    [ localOneArgNotShadowedByImportedMultiArg
    , localMultiArgStillGetsHelper
    , importedMultiArgViaQualifiedName
    , collectSkipsUnaryCtors
    , importedMultiArgViaImportAlias
    , fifoLikeCtorValueUsesAllShareOneHelper
    , fifoRealLoweringChainStillEmitsHelper
    ]


{-| Classic zmachine collision: local `Continue` (1-arg) must not pick up
`Types.Continue` (2-arg) via a bare short-name arity key.
-}
localOneArgNotShadowedByImportedMultiArg : TestResult
localOneArgNotShadowedByImportedMultiArg =
    let
        packageArities =
            Dict.empty
                |> Dict.set "Types.Continue" 2
                |> Dict.set "Execute.Error" 2

        file =
            emptyFile "Execute"
                [ { moduleName = "Types", alias = Nothing, exposing_ = Just ExposeAll } ]
                [ DeclCustomType
                    { name = "Outcome"
                    , documentation = Nothing
                    , generics = []
                    , constructors =
                        [ { name = "Continue", arguments = [ TypeGeneric "ZMachine" ] }
                        , { name = "Error"
                          , arguments = [ TypeGeneric "ZMachineError", TypeGeneric "ZMachine" ]
                          }
                        ]
                    }
                , DeclFunction
                    { name = "step"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = [ PatVar "m" ]
                    , expression =
                        -- Bare local Continue (moduleName Nothing = current module).
                        ExprApplication
                            [ ExprVar { moduleName = Nothing, name = "Continue" }
                            , ExprVar { moduleName = Nothing, name = "m" }
                            ]
                    }
                ]

        printed =
            Print.print (CtorLaw.apply packageArities file)

        ok =
            not (String.contains "ctor_Continue_elmToGren" printed)
                && String.contains "Continue" printed
                && not (String.contains "Continue { first" printed)
    in
    outcome
        "local 1-arg Continue is not rewritten via Types.Continue arity"
        ok
        ("printed:\n" ++ printed)


localMultiArgStillGetsHelper : TestResult
localMultiArgStillGetsHelper =
    let
        packageArities =
            Dict.empty
                |> Dict.set "Execute.Error" 2

        file =
            emptyFile "Execute"
                []
                [ DeclCustomType
                    { name = "Outcome"
                    , documentation = Nothing
                    , generics = []
                    , constructors =
                        [ { name = "Error"
                          , arguments = [ TypeGeneric "E", TypeGeneric "M" ]
                          }
                        ]
                    }
                , DeclFunction
                    { name = "fail"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = [ PatVar "e", PatVar "m" ]
                    , expression =
                        ExprApplication
                            [ ExprVar { moduleName = Nothing, name = "Error" }
                            , ExprVar { moduleName = Nothing, name = "e" }
                            , ExprVar { moduleName = Nothing, name = "m" }
                            ]
                    }
                ]

        printed =
            Print.print (CtorLaw.apply packageArities file)

        ok =
            String.contains "ctor_Error_elmToGren" printed
                && String.contains "Error ({ first = a0, second = a1 })" printed
                && not (String.contains "third" printed)
    in
    outcome
        "local 2-arg Error gets a 2-param curried helper"
        ok
        ("printed:\n" ++ printed)


importedMultiArgViaQualifiedName : TestResult
importedMultiArgViaQualifiedName =
    let
        packageArities =
            Dict.empty
                |> Dict.set "Types.Continue" 2

        file =
            emptyFile "Run"
                [ { moduleName = "Types", alias = Nothing, exposing_ = Just ExposeAll } ]
                [ DeclFunction
                    { name = "go"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = [ PatVar "events", PatVar "m" ]
                    , expression =
                        ExprApplication
                            [ ExprVar { moduleName = Just "Types", name = "Continue" }
                            , ExprVar { moduleName = Nothing, name = "events" }
                            , ExprVar { moduleName = Nothing, name = "m" }
                            ]
                    }
                ]

        printed =
            Print.print (CtorLaw.apply packageArities file)

        ok =
            String.contains "ctor_Continue_elmToGren" printed
                && String.contains "Types.Continue ({ first = a0, second = a1 })" printed
    in
    outcome
        "qualified Types.Continue (2-arg) still gets a helper"
        ok
        ("printed:\n" ++ printed)


collectSkipsUnaryCtors : TestResult
collectSkipsUnaryCtors =
    let
        file =
            emptyFile "Execute"
                []
                [ DeclCustomType
                    { name = "Outcome"
                    , documentation = Nothing
                    , generics = []
                    , constructors =
                        [ { name = "Continue", arguments = [ TypeGeneric "M" ] }
                        , { name = "Error", arguments = [ TypeGeneric "E", TypeGeneric "M" ] }
                        , { name = "Halted", arguments = [] }
                        ]
                    }
                ]

        arities =
            CtorLaw.collectFromFile file

        ok =
            Dict.get "Execute.Continue" arities
                == Nothing
                && Dict.get "Execute.Halted" arities
                == Nothing
                && Dict.get "Execute.Error" arities
                == Just 2
    in
    outcome
        "collectFromFile only indexes multi-arg ctors"
        ok
        ("map keys: " ++ String.join ", " (Dict.keys arities))


{-| elm-ui shape: `import Elm.Internal.Model as Internal` + unsaturated
`Internal.StyleClass flag <| style` must get a curried helper when package
arities use the post-NameSub module key.
-}
importedMultiArgViaImportAlias : TestResult
importedMultiArgViaImportAlias =
    let
        packageArities =
            Dict.empty
                |> Dict.set "Elm.Internal.Model.StyleClass" 2

        file =
            emptyFile "Elm.Element"
                [ { moduleName = "Elm.Internal.Model"
                  , alias = Just "Internal"
                  , exposing_ = Nothing
                  }
                ]
                [ DeclFunction
                    { name = "alpha"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = [ PatVar "flag", PatVar "style" ]
                    , expression =
                        ExprBinop
                            { operator = "<|"
                            , left =
                                ExprApplication
                                    [ ExprVar
                                        { moduleName = Just "Internal"
                                        , name = "StyleClass"
                                        }
                                    , ExprVar
                                        { moduleName = Nothing, name = "flag" }
                                    ]
                            , right =
                                ExprVar
                                    { moduleName = Nothing, name = "style" }
                            }
                    }
                ]

        printed =
            Print.print (CtorLaw.apply packageArities file)

        ok =
            String.contains "ctor_StyleClass_elmToGren" printed
                && String.contains "ctor_StyleClass_elmToGren flag" printed
                && not (String.contains "(Internal.StyleClass flag)" printed)
    in
    outcome
        "import-alias Internal.StyleClass gets a curried helper"
        ok
        ("printed:\n" ++ printed)


{-| Mirrors jfmengels/elm-review's `Vendor.Fifo` shape (2-arg local ctor `Fifo`)
and its three real value-position uses: a fully-applied ctor in `insert`'s
body, a ctor application on the *right* of a `<|` pipeline in `remove`, and a
ctor application nested inside a tuple argument in `remove`. All three must
rewrite to the *same* shared `ctor_Fifo_elmToGren` helper, and that helper
declaration must actually be emitted into the file.
-}
fifoLikeCtorValueUsesAllShareOneHelper : TestResult
fifoLikeCtorValueUsesAllShareOneHelper =
    let
        printed =
            Print.print (CtorLaw.apply Dict.empty fifoFixtureFile)

        helperOccurrences =
            Array.length (String.split "ctor_Fifo_elmToGren" printed) - 1

        ok =
            -- One shared helper declaration plus three rewritten call sites.
            helperOccurrences
                == 4
                && String.contains "ctor_Fifo_elmToGren a0 a1 =" printed
    in
    outcome
        "Fifo-shaped 2-arg ctor: application, <| right-side, and tuple-nested uses all share one emitted helper"
        ok
        ("helper occurrences: "
            ++ String.fromInt helperOccurrences
            ++ "\nprinted:\n"
            ++ printed
        )


{-| Same fixture as `fifoLikeCtorValueUsesAllShareOneHelper`, but driven
through the *actual* per-module lowering chain `Transform.Pipeline` runs
(`BareResolve -> NameSub -> RecordAlias -> CtorLaw`) instead of calling
`CtorLaw.apply` directly on the raw fixture. NameSub rewrites `::` to
`Array.pushFirst` *before* CtorLaw ever sees the file — this is the fidelity
gap a hand-built CtorLaw-only fixture cannot see, since real elm-review ASTs
always reach CtorLaw already lowered by the earlier passes.
-}
fifoRealLoweringChainStillEmitsHelper : TestResult
fifoRealLoweringChainStillEmitsHelper =
    let
        emptyRegistry : Registry
        emptyRegistry =
            { packageOrder = [], packages = Dict.empty, modules = Dict.empty }

        lowered =
            fifoFixtureFile
                |> BareResolve.apply
                |> NameSub.apply emptyRegistry
                |> RecordAlias.apply Dict.empty
                |> CtorLaw.apply Dict.empty

        printed =
            Print.print lowered

        helperOccurrences =
            Array.length (String.split "ctor_Fifo_elmToGren" printed) - 1

        ok =
            helperOccurrences
                == 4
                && String.contains "ctor_Fifo_elmToGren a0 a1 =" printed
    in
    outcome
        "Fifo fixture through the real BareResolve -> NameSub -> RecordAlias -> CtorLaw chain still emits one shared helper"
        ok
        ("helper occurrences: "
            ++ String.fromInt helperOccurrences
            ++ "\nprinted:\n"
            ++ printed
        )


{-| Mirrors jfmengels/elm-review's `Vendor.Fifo` shape (2-arg local ctor `Fifo`)
and its three real value-position uses: a fully-applied ctor in `insert`'s
body, a ctor application on the *right* of a `<|` pipeline in `remove`, and a
ctor application nested inside a tuple argument in `remove`.
-}
fifoFixtureFile : File
fifoFixtureFile =
    let
        fifoRef =
            { moduleName = Nothing, name = "Fifo" }

        file =
            emptyFile "Vendor.Fifo"
                []
                [ DeclCustomType
                    { name = "Fifo"
                    , documentation = Nothing
                    , generics = [ "a" ]
                    , constructors =
                        [ { name = "Fifo"
                          , arguments =
                              [ TypeGeneric "listA", TypeGeneric "listA" ]
                          }
                        ]
                    }
                , DeclFunction
                    { name = "insert"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments =
                        [ PatVar "a"
                        , PatNamed
                            { ref = fifoRef
                            , arguments = [ PatVar "front", PatVar "back" ]
                            }
                        ]
                    , expression =
                        -- `Fifo front (a :: back)` — fully-applied ctor value use.
                        ExprApplication
                            [ ExprVar fifoRef
                            , ExprVar { moduleName = Nothing, name = "front" }
                            , ExprBinop
                                { operator = "::"
                                , left = ExprVar { moduleName = Nothing, name = "a" }
                                , right = ExprVar { moduleName = Nothing, name = "back" }
                                }
                            ]
                    }
                , DeclFunction
                    { name = "remove"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = [ PatVar "fifo" ]
                    , expression =
                        ExprCase
                            { expression = ExprVar { moduleName = Nothing, name = "fifo" }
                            , cases =
                                [ { pattern =
                                        PatNamed { ref = fifoRef, arguments = [ PatList [], PatList [] ] }
                                  , body = ExprVar { moduleName = Nothing, name = "Nothing" }
                                  }
                                , { pattern =
                                        PatNamed
                                            { ref = fifoRef
                                            , arguments = [ PatList [], PatVar "back" ]
                                            }
                                  , body =
                                        -- `remove <| Fifo (List.reverse back) []` — ctor use on
                                        -- the *right* of a `<|` pipeline.
                                        ExprBinop
                                            { operator = "<|"
                                            , left = ExprVar { moduleName = Nothing, name = "remove" }
                                            , right =
                                                ExprApplication
                                                    [ ExprVar fifoRef
                                                    , ExprApplication
                                                        [ ExprVar { moduleName = Just "List", name = "reverse" }
                                                        , ExprVar { moduleName = Nothing, name = "back" }
                                                        ]
                                                    , ExprList []
                                                    ]
                                            }
                                  }
                                , { pattern =
                                        PatNamed
                                            { ref = fifoRef
                                            , arguments =
                                                [ PatCons
                                                    { head = PatVar "next", tail = PatVar "rest" }
                                                , PatVar "back"
                                                ]
                                            }
                                  , body =
                                        -- `Just ( next, Fifo rest back )` — ctor use nested
                                        -- inside a tuple inside another application's argument.
                                        ExprApplication
                                            [ ExprVar { moduleName = Nothing, name = "Just" }
                                            , ExprTuple
                                                [ ExprVar { moduleName = Nothing, name = "next" }
                                                , ExprApplication
                                                    [ ExprVar fifoRef
                                                    , ExprVar { moduleName = Nothing, name = "rest" }
                                                    , ExprVar { moduleName = Nothing, name = "back" }
                                                    ]
                                                ]
                                            ]
                                  }
                                ]
                            }
                    }
                ]
    in
    file


-- helpers -------------------------------------------------------------------


emptyFile : String -> Array { moduleName : String, alias : Maybe String, exposing_ : Maybe Exposing } -> Array Declaration -> File
emptyFile moduleName imports declarations =
    { schemaVersion = 1
    , moduleDefinition =
        { kind = NormalModule
        , moduleName = moduleName
        , exposing_ = ExposeAll
        }
    , comments = []
    , imports = imports
    , declarations = declarations
    }


outcome : String -> Bool -> String -> TestResult
outcome name passed details =
    { name = name
    , passed = passed
    , details = details
    }
