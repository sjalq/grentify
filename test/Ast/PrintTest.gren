module Ast.PrintTest exposing (tests)

{-| Print layout checks: lambda bodies with block expressions.
-}

import Array exposing (Array)
import Ast.Print as Print
import Ast.Types exposing
    ( Declaration(..)
    , Exposing(..)
    , Expr(..)
    , File
    , LetDecl(..)
    , ModuleKind(..)
    , Pattern(..)
    )
import Math
import String


type alias TestResult =
    { name : String
    , passed : Bool
    , details : String
    }


tests : Array TestResult
tests =
    [ lambdaLetBreaksAfterArrow
    , simpleLambdaStaysInline
    , caseArmStillMultiline
    , basicsFalseKeepsModuleWhenLocalFalseCtor
    , recordFieldLetIsParenthesized
    , multiDeclLetIfKeepsSiblingBinds
    , fixedListPatternPrintsAsArray
    , binopLetRhsBreaksAfterOperator
    , applicationLetArgStartsOwnLine
    , nestedLetStaysValid
    -- Hex leaves: print as decimal of the Int value (not "0x" ++ decimal digits).
    , hexExprPrintsAsDecimalOfValue
    , hexPatPrintsAsDecimalOfValue
    , hexAndIntPrintIdentical
    , hexPrintRoundTripsViaToInt
    , hexNeverEmitsFakeHexCodec
    , hexCharExtraAsciiCanary
    , hexPropertySuite
    -- Unicode escape format: control chars must emit as \u{XXXX}, not \uXXXX
    , stringWithControlCharEmitsUnicodeEscape
    , charLiteralWithControlCharEmitsUnicodeEscape
    -- Operators in record fields must print with parentheses (not bare)
    , operatorInRecordFieldParenthesized
    -- W5.1d: the giant embedded-docs record literal stays single-line + valid
    , embeddedDocsRecordStaysSingleLine
    ]


{-| Gren rejects mid-line `{ field = let` (UNFINISHED LET), even parenthesized.
Break after `=` and indent the block so `let` owns its column.
-}
recordFieldLetIsParenthesized : TestResult
recordFieldLetIsParenthesized =
    let
        file =
            emptyFile
                [ DeclFunction
                    { name = "widget"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = []
                    , expression =
                        ExprRecord
                            [ { name = "class"
                              , value =
                                    ExprLet
                                        { declarations =
                                            [ LetDestructure
                                                { pattern = PatVar "c"
                                                , expression =
                                                    ExprString "ok"
                                                }
                                            ]
                                        , expression =
                                            ExprVar { moduleName = Nothing, name = "c" }
                                        }
                              }
                            ]
                    }
                ]

        printed =
            Print.print file

        ok =
            not (String.contains "class = let" printed)
                && not (String.contains "class = (let" printed)
                && String.contains "class =" printed
                && String.contains "\n" printed
                && String.contains "let" printed
                && String.contains "in" printed
    in
    outcome
        "record field let breaks after = and indents"
        ok
        ("printed:\n" ++ printed)




{-| Gren rejects `\\x -> let` on one line (UNFINISHED LET).
-}
lambdaLetBreaksAfterArrow : TestResult
lambdaLetBreaksAfterArrow =
    let
        file =
            emptyFile
                [ DeclFunction
                    { name = "fold"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = []
                    , expression =
                        ExprApplication
                            [ ExprVar { moduleName = Just "Array", name = "foldl" }
                            , ExprLambda
                                { arguments = [ PatVar "x", PatVar "acc" ]
                                , expression =
                                    ExprLet
                                        { declarations =
                                            [ LetDestructure
                                                { pattern = PatVar "y"
                                                , expression =
                                                    ExprVar { moduleName = Nothing, name = "x" }
                                                }
                                            ]
                                        , expression =
                                            ExprVar { moduleName = Nothing, name = "y" }
                                        }
                                }
                            , ExprVar { moduleName = Nothing, name = "init" }
                            , ExprVar { moduleName = Nothing, name = "items" }
                            ]
                    }
                ]

        printed =
            Print.print file

        ok =
            not (String.contains "-> let" printed)
                && String.contains "->\n" printed
                && String.contains "let" printed
    in
    outcome
        "lambda with let body breaks after ->"
        ok
        ("printed:\n" ++ printed)


simpleLambdaStaysInline : TestResult
simpleLambdaStaysInline =
    let
        file =
            emptyFile
                [ DeclFunction
                    { name = "inc"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = []
                    , expression =
                        ExprLambda
                            { arguments = [ PatVar "n" ]
                            , expression =
                                ExprBinop
                                    { operator = "+"
                                    , left = ExprVar { moduleName = Nothing, name = "n" }
                                    , right = ExprInt 1
                                    }
                            }
                    }
                ]

        printed =
            Print.print file

        ok =
            String.contains "\\n -> n + 1" printed
                || String.contains "\\n -> (n + 1)" printed
    in
    outcome
        "simple lambda stays single-line"
        ok
        ("printed:\n" ++ printed)


caseArmStillMultiline : TestResult
caseArmStillMultiline =
    let
        file =
            emptyFile
                [ DeclFunction
                    { name = "pick"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = [ PatVar "v" ]
                    , expression =
                        ExprCase
                            { expression = ExprVar { moduleName = Nothing, name = "v" }
                            , cases =
                                [ { pattern = PatVar "x"
                                  , body = ExprVar { moduleName = Nothing, name = "x" }
                                  }
                                ]
                            }
                    }
                ]

        printed =
            Print.print file

        ok =
            String.contains "when" printed
                && String.contains "->\n" printed
    in
    outcome
        "case arms still break after ->"
        ok
        ("printed:\n" ++ printed)


{-| Local `False` ADT ctor must not steal `Basics.False` (postgrest-queries).
-}
basicsFalseKeepsModuleWhenLocalFalseCtor : TestResult
basicsFalseKeepsModuleWhenLocalFalseCtor =
    let
        file =
            emptyFile
                [ DeclCustomType
                    { name = "Value"
                    , documentation = Nothing
                    , generics = []
                    , constructors =
                        [ { name = "True", arguments = [] }
                        , { name = "False", arguments = [] }
                        ]
                    }
                , DeclFunction
                    { name = "flag"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = []
                    , expression =
                        ExprVar { moduleName = Just "Basics", name = "False" }
                    }
                ]

        printed =
            Print.print file

        ok =
            String.contains "Basics.False" printed
                && not (String.contains "flag =\n    False\n" printed)
    in
    outcome
        "Basics.False stays qualified when local False exists"
        ok
        ("printed:\n" ++ printed)


{-| Multi-decl let whose earlier binding is an if must print later bindings as
siblings, not nested under else (iso8601 fromTime class; format post-pass also
guards this, but Print itself must emit correct structure).
-}
multiDeclLetIfKeepsSiblingBinds : TestResult
multiDeclLetIfKeepsSiblingBinds =
    let
        file =
            emptyFile
                [ DeclFunction
                    { name = "fromTime"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = [ PatVar "ms" ]
                    , expression =
                        ExprLet
                            { declarations =
                                [ LetDestructure
                                    { pattern =
                                        PatRecordBind
                                            [ { name = "first", pattern = PatVar "years" }
                                            , { name = "second", pattern = PatVar "remainingDays" }
                                            ]
                                    , expression =
                                        ExprIf
                                            { condition =
                                                ExprBinop
                                                    { operator = "=="
                                                    , left = ExprVar { moduleName = Nothing, name = "ms" }
                                                    , right = ExprInt 0
                                                    }
                                            , then_ =
                                                ExprApplication
                                                    [ ExprVar { moduleName = Nothing, name = "daysToYears" }
                                                    , ExprInt 1
                                                    ]
                                            , else_ =
                                                ExprApplication
                                                    [ ExprVar { moduleName = Nothing, name = "daysToYears" }
                                                    , ExprVar { moduleName = Nothing, name = "ms" }
                                                    ]
                                            }
                                    }
                                , LetDestructure
                                    { pattern =
                                        PatRecordBind
                                            [ { name = "first", pattern = PatVar "months" }
                                            , { name = "second", pattern = PatVar "daysInMonth" }
                                            ]
                                    , expression =
                                        ExprApplication
                                            [ ExprVar { moduleName = Nothing, name = "daysToMonths" }
                                            , ExprVar { moduleName = Nothing, name = "years" }
                                            , ExprVar { moduleName = Nothing, name = "remainingDays" }
                                            ]
                                    }
                                ]
                            , expression =
                                ExprVar { moduleName = Nothing, name = "months" }
                            }
                    }
                ]

        printed =
            Print.print file

        -- months bind must appear after the if's else arm, not glued to it
        ok =
            String.contains "daysToYears ms" printed
                && String.contains "first = months" printed
                && not (String.contains "daysToYears ms { first = months" printed)
                && not (String.contains "daysToYears ms({ first = months" printed)
    in
    outcome
        "multi-decl let with if keeps sibling record binds"
        ok
        ("printed:\n" ++ printed)


{-| Gren rejects `|| (let` mid-line (UNFINISHED LET). Break after the operator.
-}
binopLetRhsBreaksAfterOperator : TestResult
binopLetRhsBreaksAfterOperator =
    let
        file =
            emptyFile
                [ DeclFunction
                    { name = "ok"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = []
                    , expression =
                        ExprBinop
                            { operator = "||"
                            , left = ExprVar { moduleName = Nothing, name = "a" }
                            , right =
                                ExprLet
                                    { declarations =
                                        [ LetDestructure
                                            { pattern = PatVar "b"
                                            , expression =
                                                ExprVar { moduleName = Nothing, name = "c" }
                                            }
                                        ]
                                    , expression =
                                        ExprVar { moduleName = Nothing, name = "b" }
                                    }
                            }
                    }
                ]

        printed =
            Print.print file

        ok =
            not (String.contains "|| (let" printed)
                && not (String.contains "|| let" printed)
                && String.contains "||" printed
                && String.contains "let" printed
    in
    outcome
        "binop with let RHS breaks after operator"
        ok
        ("printed:\n" ++ printed)


{-| D25: ExprApplication with ExprLet argument must print `let` on its own line.
The opening paren must be followed by newline, with `let` indented deeper.
-}
applicationLetArgStartsOwnLine : TestResult
applicationLetArgStartsOwnLine =
    let
        file =
            emptyFile
                [ DeclFunction
                    { name = "test"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = []
                    , expression =
                        ExprApplication
                            [ ExprVar { moduleName = Just "Test", name = "describe" }
                            , ExprString "apply"
                            , ExprLet
                                { declarations =
                                    [ LetDestructure
                                        { pattern = PatVar "fun4"
                                        , expression =
                                            ExprInt 42
                                        }
                                    ]
                                , expression =
                                    ExprVar { moduleName = Nothing, name = "fun4" }
                                }
                            ]
                    }
                ]

        printed =
            Print.print file

        ok =
            not (String.contains "(let" printed)
                && not (String.contains ") (let" printed)
                && String.contains "(\n" printed
                && String.contains "let\n" printed
                && String.contains "fun4" printed
    in
    outcome
        "application with let arg: let starts own line after newline paren"
        ok
        ("printed:\n" ++ printed)


{-| Nested let in application argument: inner let must also start own line.
-}
nestedLetStaysValid : TestResult
nestedLetStaysValid =
    let
        file =
            emptyFile
                [ DeclFunction
                    { name = "nested"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = []
                    , expression =
                        ExprApplication
                            [ ExprVar { moduleName = Nothing, name = "map" }
                            , ExprLet
                                { declarations =
                                    [ LetDestructure
                                        { pattern = PatVar "x"
                                        , expression =
                                            ExprLet
                                                { declarations =
                                                    [ LetDestructure
                                                        { pattern = PatVar "y"
                                                        , expression = ExprInt 1
                                                        }
                                                    ]
                                                , expression =
                                                    ExprVar { moduleName = Nothing, name = "y" }
                                                }
                                        }
                                    ]
                                , expression =
                                    ExprVar { moduleName = Nothing, name = "x" }
                                }
                            , ExprVar { moduleName = Nothing, name = "items" }
                            ]
                    }
                ]

        printed =
            Print.print file

        ok =
            String.contains "let" printed
                && not (String.contains "(let" printed)
                && not (String.contains "=(let" printed)
    in
    outcome
        "nested let in application: both lets valid"
        ok
        ("printed:\n" ++ printed)


{-| Fixed list patterns stay as Gren array patterns in when arms (hang-class
guard: do not force cons peels for multi-arm fixed lists).
-}
fixedListPatternPrintsAsArray : TestResult
fixedListPatternPrintsAsArray =
    let
        file =
            emptyFile
                [ DeclFunction
                    { name = "rgb"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = [ PatVar "xs" ]
                    , expression =
                        ExprCase
                            { expression = ExprVar { moduleName = Nothing, name = "xs" }
                            , cases =
                                [ { pattern =
                                        PatList
                                            [ PatVar "r"
                                            , PatVar "g"
                                            , PatVar "b"
                                            ]
                                  , body =
                                        ExprApplication
                                            [ ExprVar { moduleName = Nothing, name = "triple" }
                                            , ExprVar { moduleName = Nothing, name = "r" }
                                            , ExprVar { moduleName = Nothing, name = "g" }
                                            , ExprVar { moduleName = Nothing, name = "b" }
                                            ]
                                  }
                                ]
                            }
                    }
                ]

        printed =
            Print.print file

        ok =
            String.contains "when" printed
                && (String.contains "[ r, g, b ]" printed
                        || String.contains "[r, g, b]" printed
                        || String.contains "[ r,g,b ]" printed
                   )
                && not (String.contains " :: " printed)
    in
    outcome
        "fixed list pattern prints as array not cons peel"
        ok
        ("printed:\n" ++ printed)


-- Hex literal printing ------------------------------------------------------
--
-- AST holds Int values for both ExprHex/PatHex and ExprInt/PatInt. The only
-- correct printer for a bare Int is decimal (String.fromInt). Emitting
-- ("0x" ++ String.fromInt n) is a fake hex codec: 0x61 (value 97) becomes
-- "0x97", which Gren reads as 151. That class of bug silently corrupts every
-- unicode/char table ported from Elm hex literals (e.g. stil4m Char.Extra).


{-| Unit canary: known Elm hex code points print as their true decimal value.
-}
hexCharExtraAsciiCanary : TestResult
hexCharExtraAsciiCanary =
    let
        -- Original Elm: 0x61..0x7A (a-z), 0x41..0x5A (A-Z), 0x30..0x39 (0-9)
        samples =
            [ { value = 0x61, label = "a" }
            , { value = 0x7A, label = "z" }
            , { value = 0x41, label = "A" }
            , { value = 0x5A, label = "Z" }
            , { value = 0x30, label = "0" }
            , { value = 0x39, label = "9" }
            , { value = 0x5F, label = "_" }
            ]

        failures =
            samples
                |> Array.keepIf
                    (\s ->
                        not (exprHexOk s.value)
                            || not (patHexOk s.value)
                    )
    in
    outcome
        "hex Char.Extra ASCII canary prints true decimal"
        (Array.isEmpty failures)
        ("failed samples: "
            ++ String.join ", "
                (Array.map
                    (\s ->
                        s.label
                            ++ "="
                            ++ String.fromInt s.value
                            ++ " expr="
                            ++ printExprBinding "n" (ExprHex s.value)
                    )
                    failures
                )
        )


{-| ExprHex n must print the same digits as String.fromInt n (no 0x prefix).
-}
hexExprPrintsAsDecimalOfValue : TestResult
hexExprPrintsAsDecimalOfValue =
    let
        value =
            0x61

        printed =
            printExprBinding "n" (ExprHex value)

        ok =
            exprHexOk value
    in
    outcome
        "ExprHex prints as decimal of value"
        ok
        ("printed:\n" ++ printed)


{-| PatHex n must print the same digits as String.fromInt n.
-}
hexPatPrintsAsDecimalOfValue : TestResult
hexPatPrintsAsDecimalOfValue =
    let
        value =
            0x7A

        printed =
            printPatBinding "n" (PatHex value)

        ok =
            patHexOk value
    in
    outcome
        "PatHex prints as decimal of value"
        ok
        ("printed:\n" ++ printed)


{-| Hex and Int leaves with the same Int are observationally identical in print.
-}
hexAndIntPrintIdentical : TestResult
hexAndIntPrintIdentical =
    let
        value =
            255

        hexPrinted =
            printExprBinding "n" (ExprHex value)

        intPrinted =
            printExprBinding "n" (ExprInt value)

        ok =
            hexPrinted == intPrinted
    in
    outcome
        "ExprHex and ExprInt print identically for same value"
        ok
        ("hex:\n" ++ hexPrinted ++ "\nint:\n" ++ intPrinted)


{-| Printed hex leaf must round-trip through String.toInt to the same Int.
Uses the known Print layout `name =\n    <body>`.
-}
hexPrintRoundTripsViaToInt : TestResult
hexPrintRoundTripsViaToInt =
    let
        value =
            0x0344

        printed =
            printExprBinding "n" (ExprHex value)

        ok =
            when extractExprBody printed is
                Just body ->
                    when String.toInt body is
                        Just n ->
                            n == value

                        Nothing ->
                            False

                Nothing ->
                    False
    in
    outcome
        "hex print round-trips via String.toInt"
        ok
        ("printed:\n" ++ printed)


{-| The broken codec is exactly ("0x" ++ String.fromInt n). For any n whose
decimal digits are valid hex, that form parses as a *different* Int under Gren.
Property: we never emit that form for ExprHex/PatHex.
-}
hexNeverEmitsFakeHexCodec : TestResult
hexNeverEmitsFakeHexCodec =
    let
        -- Values whose decimal spelling is valid hex digits (the danger zone).
        danger =
            [ 10, 11, 15, 61, 97, 122, 255, 836, 8559 ]

        failures =
            danger
                |> Array.keepIf
                    (\n ->
                        let
                            fake =
                                "0x" ++ String.fromInt n
                        in
                        String.contains fake (printExprBinding "n" (ExprHex n))
                            || String.contains fake (printPatBinding "n" (PatHex n))
                    )
    in
    outcome
        "hex never emits fake 0x++decimal codec"
        (Array.isEmpty failures)
        ("emitted fake form for: "
            ++ String.join ", " (Array.map String.fromInt failures)
        )


{-| String containing control character (ESC, code 27) must emit \u{001B} form.
-}
stringWithControlCharEmitsUnicodeEscape : TestResult
stringWithControlCharEmitsUnicodeEscape =
    let
        -- Create a string containing ESC character (code 27)
        escChar = Char.fromCode 27 |> String.fromChar
        testString = "prefix" ++ escChar ++ "suffix"

        file =
            emptyFile
                [ DeclFunction
                    { name = "test"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = []
                    , expression = ExprString testString
                    }
                ]

        printed =
            Print.print file

        ok =
            String.contains "\\u{001B}" printed
                && not (String.contains "\\u001B" printed)
                && not (String.contains "\\u001b" printed)
    in
    outcome
        "string with control char emits \\u{001B} format"
        ok
        ("printed:\n" ++ printed)


{-| Char literal with control character (ESC, code 27) must emit \u{001B} form.
-}
charLiteralWithControlCharEmitsUnicodeEscape : TestResult
charLiteralWithControlCharEmitsUnicodeEscape =
    let
        -- Create a pattern/literal with ESC character (code 27)
        escChar = Char.fromCode 27 |> String.fromChar

        file =
            emptyFile
                [ DeclFunction
                    { name = "test"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = []
                    , expression = ExprChar escChar
                    }
                ]

        printed =
            Print.print file

        ok =
            String.contains "\\u{001B}" printed
                && not (String.contains "\\u001B" printed)
                && not (String.contains "\\u001b" printed)
    in
    outcome
        "char with control char emits \\u{001B} format"
        ok
        ("printed:\n" ++ printed)


{-| Property suite over a deterministic integer domain.

Properties (∀ n in sample):
  P1. print(ExprHex n) body == String.fromInt n
  P2. print(PatHex n) pattern == String.fromInt n
  P3. print(ExprHex n) == print(ExprInt n)
  P4. print(PatHex n) == print(PatInt n)
  P5. String.toInt (print ExprHex n body) == Just n
  P6. print does not contain ("0x" ++ String.fromInt n)
-}
hexPropertySuite : TestResult
hexPropertySuite =
    let
        charBand =
            Array.initialize 256 0 (\i -> i)

        lcgSamples =
            lcgTake 2000 0x9E3779B9

        edges =
            [ 0
            , 1
            , -1
            , 9
            , 10
            , 15
            , 16
            , 255
            , 256
            , -97
            , 0x61
            , 0x7A
            , 0x41
            , 0x5A
            , 0x30
            , 0x39
            , 0x0344
            , 0x216F
            , 999999
            , -999999
            ]

        domain =
            Array.append charBand (Array.append edges lcgSamples)

        firstFailure =
            Array.foldl
                (\n acc ->
                    when acc is
                        Just _ ->
                            acc

                        Nothing ->
                            hexPropertyFailure n
                )
                Nothing
                domain
    in
    when firstFailure is
        Nothing ->
            outcome
                "hex property suite (exhaustive 0..255 + LCG + edges)"
                True
                ("checked " ++ String.fromInt (Array.length domain) ++ " values")

        Just detail ->
            outcome
                "hex property suite (exhaustive 0..255 + LCG + edges)"
                False
                detail


hexPropertyFailure : Int -> Maybe String
hexPropertyFailure n =
    let
        exprHex =
            printExprBinding "n" (ExprHex n)

        exprInt =
            printExprBinding "n" (ExprInt n)

        patHex =
            printPatBinding "n" (PatHex n)

        patInt =
            printPatBinding "n" (PatInt n)

        expect =
            String.fromInt n

        fake =
            "0x" ++ expect

        p1 =
            exprHexOk n

        p2 =
            patHexOk n

        p3 =
            exprHex == exprInt

        p4 =
            patHex == patInt

        p5 =
            when extractExprBody exprHex is
                Just body ->
                    when String.toInt body is
                        Just got ->
                            got == n

                        Nothing ->
                            False

                Nothing ->
                    False

        p6 =
            not (String.contains fake exprHex)
                && not (String.contains fake patHex)
    in
    if p1 && p2 && p3 && p4 && p5 && p6 then
        Nothing

    else
        Just
            ("n="
                ++ expect
                ++ " exprHex=\n"
                ++ exprHex
                ++ "\np1="
                ++ boolStr p1
                ++ " p2="
                ++ boolStr p2
                ++ " p3="
                ++ boolStr p3
                ++ " p4="
                ++ boolStr p4
                ++ " p5="
                ++ boolStr p5
                ++ " p6="
                ++ boolStr p6
            )


{-| ExprOperator in record field values must print with parentheses to avoid
"UNFINISHED RECORD" parse errors. Field value cannot be empty or bare operator.
-}
operatorInRecordFieldParenthesized : TestResult
operatorInRecordFieldParenthesized =
    let
        file =
            emptyFile
                [ DeclFunction
                    { name = "getOp"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = []
                    , expression =
                        ExprRecord
                            [ { name = "add"
                              , value = ExprOperator "+"
                              }
                            ]
                    }
                ]

        printed =
            Print.print file

        -- Operator must be parenthesized to parse as a valid record literal
        ok =
            String.contains "add = (+)" printed
                && not (String.contains "add = +" printed)
    in
    outcome
        "operator in record field prints parenthesized"
        ok
        ("printed:\n" ++ printed)


{-| W5.1d "UNFINISHED RECORD": the ElmCore embedded-docs specimen is a list of
deeply nested record literals whose string fields hold multi-line doc comments
and whose `tipe` fields are constructor-applied records. Gren records are always
one line, so the body must render as a single physical line: string newlines
escaped to `\n`, nested constructor payloads parenthesized inline. A raw newline
inside the record braces is exactly the layout Gren rejects with UNFINISHED
RECORD, so the body must contain none.
-}
embeddedDocsRecordStaysSingleLine : TestResult
embeddedDocsRecordStaysSingleLine =
    let
        tipe =
            -- `Elm.Type.Type String (List Type)` lowered to a multi-arg ctor:
            -- the printer emits `Type ({ first = …, second = … })`.
            ExprApplication
                [ ExprVar { moduleName = Nothing, name = "Type" }
                , ExprString "Array.Array"
                , ExprList
                    [ ExprApplication
                        [ ExprVar { moduleName = Nothing, name = "Var" }
                        , ExprString "a"
                        ]
                    ]
                ]

        body =
            ExprList
                [ ExprRecord
                    [ { name = "name", value = ExprString "Array" }
                    , { name = "comment", value = ExprString " Fast arrays.\n\n# Arrays\n@docs Array\n" }
                    , { name = "aliases", value = ExprList [] }
                    , { name = "values"
                      , value =
                            ExprList
                                [ ExprRecord
                                    [ { name = "name", value = ExprString "append" }
                                    , { name = "tipe", value = tipe }
                                    ]
                                ]
                      }
                    ]
                ]

        printed =
            printExprBinding "dependencyModules" body

        recordBody =
            -- Everything the printer emitted for the RHS, minus the leading
            -- indent and trailing newline, so only interior breaks remain.
            when Array.last (String.split "dependencyModules =" printed) is
                Just tail ->
                    String.trim tail

                Nothing ->
                    printed

        ok =
            -- The whole record body is one physical line (no raw newline that
            -- Gren would reject with UNFINISHED RECORD).
            not (String.contains "\n" recordBody)
                -- Doc-comment newlines survived as escapes, not raw breaks.
                && String.contains "\\n\\n# Arrays" printed
                -- Nested constructor payload is parenthesized inline.
                && String.contains "Type ({ first = " printed
    in
    outcome
        "embedded-docs record literal stays single-line and valid"
        ok
        ("printed:\n" ++ printed)


-- helpers -------------------------------------------------------------------


emptyFile : Array Declaration -> File
emptyFile declarations =
    { schemaVersion = 1
    , moduleDefinition =
        { kind = NormalModule
        , moduleName = "Example"
        , exposing_ = ExposeAll
        }
    , comments = []
    , imports = []
    , declarations = declarations
    }


outcome : String -> Bool -> String -> TestResult
outcome name passed details =
    { name = name
    , passed = passed
    , details = details
    }


printExprBinding : String -> Expr -> String
printExprBinding name expression =
    Print.print
        (emptyFile
            [ DeclFunction
                { name = name
                , documentation = Nothing
                , signature = Nothing
                , arguments = []
                , expression = expression
                }
            ]
        )


printPatBinding : String -> Pattern -> String
printPatBinding name pattern =
    Print.print
        (emptyFile
            [ DeclFunction
                { name = "pick"
                , documentation = Nothing
                , signature = Nothing
                , arguments = [ PatVar "v" ]
                , expression =
                    ExprCase
                        { expression = ExprVar { moduleName = Nothing, name = "v" }
                        , cases =
                            [ { pattern = pattern
                              , body = ExprVar { moduleName = Nothing, name = name }
                              }
                            ]
                        }
                }
            ]
        )


{-| Print layout for a nullary binding is `name =\n    <body>`.
-}
exprHexOk : Int -> Bool
exprHexOk n =
    let
        printed =
            printExprBinding "n" (ExprHex n)

        expect =
            String.fromInt n
    in
    String.contains ("n =\n    " ++ expect) printed
        && not (String.contains ("0x" ++ expect) printed)


{-| Pattern arm layout includes `<pat> ->` after `when … is`.
-}
patHexOk : Int -> Bool
patHexOk n =
    let
        printed =
            printPatBinding "n" (PatHex n)

        expect =
            String.fromInt n
    in
    String.contains (expect ++ " ->") printed
        && not (String.contains ("0x" ++ expect) printed)


{-| Body text after `n =\n    ` (single-line leaf).
-}
extractExprBody : String -> Maybe String
extractExprBody printed =
    let
        marker =
            "n =\n    "

        parts =
            String.split marker printed
    in
    when Array.get 1 parts is
        Just rest ->
            when Array.get 0 (String.split "\n" rest) is
                Just line ->
                    Just (String.trim line)

                Nothing ->
                    Nothing

        Nothing ->
            Nothing


{-| Deterministic LCG samples (mix positive/negative via bit pattern).

Builds the stream iteratively so we never recurse `count` deep.
-}
lcgTake : Int -> Int -> Array Int
lcgTake count seed0 =
    Array.foldl
        (\_ state ->
            let
                next =
                    Math.modBy 2147483647 (state.seed * 1103515245 + 12345)

                centered =
                    Math.modBy 2000001 next - 1000000
            in
            { seed = next
            , samples = Array.pushLast centered state.samples
            }
        )
        { seed = seed0, samples = [] }
        (Array.initialize count 0 (\i -> i))
        |> .samples


boolStr : Bool -> String
boolStr b =
    if b then
        "T"

    else
        "F"
